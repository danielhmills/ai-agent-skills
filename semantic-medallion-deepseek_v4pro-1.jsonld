      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The W3C standard for representing linked data as subject-predicate-object triples, forming the foundation of the Semantic Gold layer."
      }
    ],
    "http://schema.org/name": [
