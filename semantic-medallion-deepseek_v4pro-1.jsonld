  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#dataTreehouse",
    "@type": [
      "http://schema.org/Organization"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A data consultancy specializing in knowledge graph architecture and semantic technology solutions."
