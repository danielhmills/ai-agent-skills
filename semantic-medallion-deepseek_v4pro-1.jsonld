  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#step2",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Clean and type the data in the Silver layer. Critically, replace database auto-increment IDs with stable, globally unique IRIs for every entity. Define a consistent IRI naming scheme using your organization's domain namespace."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#howtoSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Clean Data and Mint IRIs in Silver"
      }
    ],
    "http://schema.org/position": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 2
      }
    ]
  },
