  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#medallionArchitecture",
    "@type": [
      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A data lakehouse design pattern with three layers: Bronze (raw ingestion), Silver (cleaned/typed), and Gold (business-level aggregates or semantic RDF)."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#analysis"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Medallion Architecture"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Medallion Architecture"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@id": "http://dbpedia.org/resource/Data_lakehouse"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#step7",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Use SPARQL to validate the knowledge graph: run customer 360 queries to verify entity resolution, lineage queries to trace provenance, and cross-system queries to confirm relationships are correctly modeled. Iterate on the ontology and templates based on query results."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#howtoSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Query and Validate"
      }
    ],
    "http://schema.org/position": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 7
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a9",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "The biggest challenge was not the RDF conversion itself, but establishing stable identifiers (IRIs) in the Silver layer. This requires upfront design of IRI naming conventions and careful governance to ensure identifiers remain consistent as new data sources are added."
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#q9",
