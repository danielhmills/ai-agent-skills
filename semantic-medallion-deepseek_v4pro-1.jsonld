  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#dataCatalog",
    "@type": [
      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A system that inventories and organizes data assets. A semantic data catalog goes beyond structural metadata to describe what things mean and how they relate, enabling relational queries rather than static table lists."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#analysis"
      }
