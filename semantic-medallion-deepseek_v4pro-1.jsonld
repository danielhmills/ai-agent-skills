  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a3",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "In the Silver layer, beyond cleaning and typing data, stable IRIs (Internationalized Resource Identifiers) are minted for every entity. These globally unique identifiers replace database auto-increment IDs and GUIDs, creating join keys that work across all systems rather than being scoped to a single database."
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#step4",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Create OTTR templates in stOTTR syntax that map your DataFrame columns to ontology properties. Each template defines how a row in your DataFrame becomes a set of RDF triples."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#howtoSection"
      }
    ],
    "http://schema.org/name": [
