  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#lineageQuery",
    "@type": [
      "http://schema.org/SoftwareSourceCode"
    ],
    "http://schema.org/codeSampleType": [
      {
        "@value": "Query"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Trace which sources contribute to customer records — identifying the provenance path from Gold entities back through Silver to Bronze datasets."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQueriesSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Data Lineage Query"
      }
    ],
    "http://schema.org/potentialAction": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#runLineage"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "SPARQL"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlEndpointService"
      }
    ],
    "http://schema.org/text": [
      {
        "@value": "PREFIX : <http://example.org/ontology#>\nPREFIX schema: <http://schema.org/>\nPREFIX prov: <http://www.w3.org/ns/prov#>\nPREFIX dcat: <http://www.w3.org/ns/dcat/>\n\nSELECT ?source ?dataset ?distribution\nWHERE {\n  :C-001 prov:wasDerivedFrom ?source .\n  ?source prov:hadPrimarySource ?dataset .\n  ?dataset dcat:distribution ?distribution .\n}"
      }
    ]
  },
