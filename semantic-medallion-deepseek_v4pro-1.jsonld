  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a4",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "The Gold layer maps Silver DataFrames to a shared ontology using OTTR templates and the maplib Python library, then publishes the result as RDF. Rather than creating separate Parquet/Delta tables requiring manual join logic, the data becomes a connected knowledge graph where relationships are stored as triples — subject-predicate-object statements — making the data inherently relational."
      }
    ]
  },
