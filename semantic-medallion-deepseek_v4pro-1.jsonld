        "@value": 3
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a7",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Entity resolution uses owl:sameAs assertions to link entities appearing in CRM, billing, and external registries. For example, a customer appearing in both the sales system and the billing system is linked via an owl:sameAs triple, creating a unified view. SPARQL queries can then navigate all facts about that customer regardless of which source system contributed them."
      }
    ]
  },
  {
