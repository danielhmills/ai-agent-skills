  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#structuralCatalog",
    "@type": [
      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A traditional data catalog that describes where data lives (tables, columns, formats) but does not understand what things mean or how they relate."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#architectureConceptsSection"
