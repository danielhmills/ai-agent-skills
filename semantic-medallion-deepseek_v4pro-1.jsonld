      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Data Catalog"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#semanticEnrichment",
    "@type": [
      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The progression of data through medallion layers: Bronze (no semantics), Silver (local semantics via identifiers), Gold (global semantics via shared vocabulary)."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#analysis"
      }
    ],
    "http://schema.org/name": [
