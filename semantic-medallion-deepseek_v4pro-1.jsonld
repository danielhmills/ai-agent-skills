      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a8",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "PROV-O (Provenance Ontology) expresses data lineage as RDF triples — recording which entities were derived from which sources, which activities generated them, and which agents were responsible. Instead of storing lineage in a separate tool with its own database, PROV-O provenance triples live IN the knowledge graph, making lineage queryable using the same SPARQL endpoint as the data itself."
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a11",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "A traditional Gold layer consists of separate Parquet or Delta tables that require manual join logic in SQL or dbt scripts to connect related records. The Semantic Gold layer is RDF where relationships are embedded in the data as triples — eliminating table hunting, manual JOINs, and fragile transformation pipelines. The data becomes inherently connected rather than depending on external join logic."
      }
    ]
  },
