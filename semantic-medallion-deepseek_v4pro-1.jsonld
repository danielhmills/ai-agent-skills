    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A layer in the medallion data architecture: Bronze (raw), Silver (cleaned with IRIs), or Gold (semantic RDF)."
      }
    ],
