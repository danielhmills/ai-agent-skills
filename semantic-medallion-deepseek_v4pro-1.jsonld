  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#dfStep3",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Use the maplib library to apply the OTTR template to the DataFrame — this is typically accomplished in a single function call that performs the complete transformation."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Apply Template via maplib"
      }
    ],
    "http://schema.org/position": [
