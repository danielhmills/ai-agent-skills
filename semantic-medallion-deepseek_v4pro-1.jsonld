  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#analysis",
    "@type": [
      "http://schema.org/Article"
    ],
    "http://schema.org/about": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#semanticMedallion"
      },
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#knowledgeGraph"
      },
