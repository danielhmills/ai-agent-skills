      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "What is the biggest implementation challenge?"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "What was the biggest challenge when building a Semantic Medallion?"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#silverIdentifiers",
    "@type": [
      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Stable, globally unique IRIs assigned to every entity in the Silver layer — serving as cross-system join keys that work across all data sources."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Silver Identifiers"
      }
    ]
  },
