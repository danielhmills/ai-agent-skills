  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#goldLayer",
    "@type": [
      "https://moderndata101.substack.com/p/the-semantic-medallion#GoldLayer",
      "http://schema.org/ArticleSection"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Silver DataFrames are mapped to a shared ontology using a common vocabulary and published as RDF via four lines of Python using maplib and OTTR templates. The relationships are in the data, not in join logic."
      }
    ],
    "http://schema.org/hasPart": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#dfToRdfProcess"
