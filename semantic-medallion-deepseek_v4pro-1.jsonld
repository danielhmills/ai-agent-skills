  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a1",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "The Semantic Medallion is an extension of the traditional Bronze/Silver/Gold data lakehouse architecture where the Gold layer is transformed into a connected knowledge graph rather than isolated clean tables. Relationships are embedded in the data itself, not in external join logic, enabling entity resolution, cross-system queries, and semantic search."
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#localSemantics",
    "@type": [
      "https://moderndata101.substack.com/p/the-semantic-medallion#SemanticEnrichmentProcess"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Silver layer: data gains local semantics through stable, globally unique IRIs that serve as cross-system join keys."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Local Semantics via Identifiers"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#dfStep2",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Define an OTTR template in stOTTR syntax that maps DataFrame column names to ontology properties — specifying which columns map to which RDF predicates."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
