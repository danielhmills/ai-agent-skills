    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "The Bronze layer handles standard raw data ingestion via orchestration tools. Data is ingested in its original format with no semantic transformation. DCAT links these raw datasets to their source systems."
      }
    ]
  },
