    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Gold layer: data is mapped to a shared ontology and published as RDF, enabling global semantic interoperability."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Global Semantics via Shared Vocabulary"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#termSemanticMedallion",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept",
      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "An architecture pattern extending the Bronze/Silver/Gold medallion with knowledge graph semantics — transforming the Gold layer into connected RDF."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#glossarySection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Semantic Medallion"
      }
    ],
    "http://schema.org/termCode": [
      {
        "@value": "SemanticMedallion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "An architecture pattern extending the Bronze/Silver/Gold medallion with knowledge graph semantics — transforming the Gold layer into connected RDF."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#glossarySection"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#entityResolution",
    "@type": [
      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Linking entities that appear across multiple data sources using owl:sameAs assertions — enabling a unified view of records spread across CRM, billing, and external registries."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#analysis"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Entity Resolution"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Entity Resolution"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a6",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "DCAT (Data Catalog Vocabulary) is a W3C standard used by data.gov, the European Data Portal, and thousands of organizations. Using DCAT provides: (1) interoperability with existing data catalog ecosystems, (2) rich standardized metadata for publishers, themes, formats, and lineage, (3) a unified graph where the catalog is part of the knowledge graph, not a separate system, and (4) built-in integration with PROV-O for provenance."
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#crossSystemQuery",
    "@type": [
      "http://schema.org/SoftwareSourceCode"
    ],
    "http://schema.org/codeSampleType": [
      {
        "@value": "Query"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Find customers with billing issues who have active contracts — navigating relationships directly across systems without manual joins or table hunting."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQueriesSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Cross-System Relationship Query"
      }
    ],
    "http://schema.org/potentialAction": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#runCrossSystem"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "SPARQL"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlEndpointService"
      }
    ],
    "http://schema.org/text": [
      {
        "@value": "PREFIX : <http://example.org/ontology#>\nPREFIX schema: <http://schema.org/>\nPREFIX prov: <http://www.w3.org/ns/prov#>\n\nSELECT ?customer ?name ?billingIssue ?contract\nWHERE {\n  ?customer a schema:Person ;\n            schema:name ?name ;\n            :hasBillingIssue ?billingIssue ;\n            :hasActiveContract ?contract .\n  ?billingIssue schema:status \"Open\" .\n  ?contract schema:status \"Active\" .\n}"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#downstreamDependencyTrace",
    "@type": [
      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Tracing impact through graph relationships to identify every downstream artifact affected by a schema or data change."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Downstream Dependency Trace"
      }
    ]
  },
