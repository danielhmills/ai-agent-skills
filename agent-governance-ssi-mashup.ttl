# ─────────────────────────────────────────────────────────────────────────────
# Core Concepts
# ─────────────────────────────────────────────────────────────────────────────

:SSIConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Self-Sovereign Identity"@en ;
    schema:description
        "An identity model in which each entity — human or software agent — generates, controls, and publishes its own verifiable credentials without requiring a centralized issuing authority. Based on DPKI, X.509 certificates, and dereferenceable HTTP URIs."@en ;
    owl:sameAs wd:Q56310525 ;
    skos:broader :DigitalIdentityConcept ;
    skos:related :WebIDConcept, :DPKIConcept, :AgentIdentityConcept .

:AgentIdentityConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Agent Identity"@en ;
    schema:description
        "The assignment of a dereferenceable HTTP URI as the stable, globally unique identifier for an AI agent. The URI is embedded in the agent's X.509 certificate Subject Alternative Name field and resolves to a public profile document for external verification."@en ;
    skos:broader :SSIConcept ;
    skos:related :WebIDConcept, :AgentProfileConcept .

:AgentProfileConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Agent Profile"@en ;
    schema:description
        "A machine-readable RDF document describing an AI agent using shared ontology terms, including prov:actedOnBehalfOf and acl:delegates relationships that create a machine-computable delegation chain from agent to authorizing human user. The profile encodes role, capability, and operational scope as verifiable triples."@en ;
    skos:broader :AgentIdentityConcept ;
    skos:related :RDFConcept, :DelegationConcept .

:AuthenticationConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Authentication"@en ;
    schema:description
        "The process by which an AI agent proves its identity to a resource server using WebID-TLS or NetID-TLS client certificate authentication: the agent presents its X.509 certificate during the TLS handshake; the server dereferences the certificate subject URI to the agent's profile document and verifies the public key match — providing cryptographic proof of identity without a central authority."@en ;
    skos:broader :SecurityConcept ;
    skos:related :WebIDConcept, :NetIDTlsConcept, :OAuthConcept .

:AuthorizationConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Authorization (ABAC)"@en ;
    schema:description
        "Attribute-Based Access Control (ABAC) defines conditional permissions evaluated against verified agent attributes — identity URI, role, delegating user identity, resource classification, time — enabling fine-grained, context-sensitive policy enforcement. Implemented via W3C Web Access Control (WAC) with acl:Read, acl:Write, and acl:Control predicates. Agent authority is always bounded by the authorizing user's own permissions."@en ;
    owl:sameAs wd:Q19825218 ;
    skos:broader :SecurityConcept ;
    skos:related :AgentIdentityConcept, :DelegationConcept .

:DataSpaceAccessConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Data Space Read & Write"@en ;
    schema:description
        "Agent interactions with data spaces (SPARQL endpoints, WebDAV stores, REST APIs, graph databases) scoped to the agent's verified identity and delegation chain. Every write operation carries prov:wasAttributedTo triples recording the agent's URI — creating an immutable, identity-bound audit trail. Named graphs isolate each agent's workspace to prevent cross-agent data bleed."@en ;
    skos:broader :DataManagementConcept ;
    skos:related :AuthorizationConcept, :ProvenanceConcept .

:ContainmentConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "AI Agent Containment"@en ;
    schema:description
        "Anthropic's strategy for limiting the blast radius of AI agent failures through three layers: environment (sandboxes, VMs, network egress controls), model (system prompts, classifiers, training), and content (per-session tool and resource access controls). Environment-layer containment is deterministic; model-layer containment is probabilistic."@en ;
    skos:broader :SecurityConcept ;
    skos:related :SandboxConcept, :BlastRadiusConcept .

:SandboxConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Execution Sandbox"@en ;
    schema:description
        "An isolated execution environment for AI agents using gVisor containers, OS-level syscall filters (Seatbelt/bubblewrap), or hypervisor-isolated virtual machines. Provides filesystem boundaries, network egress controls, and inter-process isolation. Addresses where an agent runs but not who it is or whose authority it carries."@en ;
    skos:broader :ContainmentConcept .

:BlastRadiusConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Blast Radius"@en ;
    schema:description
        "The potential scope of damage from an AI agent failure or compromise — the set of systems, data, and services affected if the agent is subverted or malfunctions. Anthropic uses blast-radius minimization as the primary design objective for agent containment architecture."@en ;
    skos:broader :SecurityConcept .

:WebIDConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "WebID"@en ;
    schema:description
        "A W3C standard for entity identification using dereferenceable HTTP URIs embedded in X.509 certificates. The URI resolves to a public profile document containing a public key, enabling decentralized, cryptographic identity verification without centralized certificate authorities."@en ;
    owl:sameAs wd:Q7980890 ;
    skos:broader :SSIConcept ;
    skos:related :NetIDTlsConcept, :X509Concept .

:NetIDTlsConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "NetID-TLS"@en ;
    schema:description
        "An extended TLS-based identity verification protocol that dereferences the hyperlink in an X.509 certificate's Subject Alternative Name to a publicly-accessible profile document, matches public and private credentials, and returns a signed certification document upon successful validation. Enables decentralized authentication without third-party identity providers."@en ;
    skos:broader :AuthenticationConcept ;
    skos:related :WebIDConcept .

:DPKIConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Decentralized Public Key Infrastructure (DPKI)"@en ;
    schema:description
        "A PKI model in which entities self-generate and self-publish their own X.509 credentials, linked via dereferenceable HTTP URIs, without requiring a centralized Certificate Authority hierarchy. Enables self-sovereign identity at web scale."@en ;
    skos:broader :SSIConcept ;
    skos:related :X509Concept .

:X509Concept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "X.509 Certificate"@en ;
    schema:description
        "A digital credential format pairing a public key with a subject identifier. In the WebID and NetID-TLS context, the subject is identified via a dereferenceable HTTP URI, enabling the certificate to serve as both a credential and a pointer to the entity's public profile document."@en ;
    owl:sameAs wd:Q217050 ;
    skos:broader :DPKIConcept .

:OAuthConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "OAuth 2.0"@en ;
    schema:description
        "An open authorization framework enabling delegated access flows — an agent (client) can obtain scoped access tokens to act on behalf of a resource owner (human user) without exposing credentials. Used alongside WebID-TLS for third-party and browser-based integration scenarios."@en ;
    owl:sameAs wd:Q326244 ;
    skos:broader :AuthenticationConcept .

:DelegationConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Agent Delegation"@en ;
    schema:description
        "The explicit, machine-readable relationship by which a human user (or higher-trust agent) authorizes a specific AI agent to act on their behalf, encoded via prov:actedOnBehalfOf and acl:delegates predicates in RDF profile documents. Agent authority is strictly bounded by the delegating entity's own authorization scope — no privilege escalation is structurally possible via delegation."@en ;
    skos:broader :AuthorizationConcept ;
    skos:related :AgentProfileConcept, :ProvenanceConcept .

:ProvenanceConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Data Provenance"@en ;
    schema:description
        "The recording of prov:wasAttributedTo and prov:wasGeneratedBy triples on every agent write operation, permanently associating data artifacts with the verified agent URI and the human user in whose name the agent acted. Enables complete, immutable audit trails at the named-graph level."@en ;
    skos:broader :DataManagementConcept ;
    skos:related :AgentIdentityConcept, :DataSpaceAccessConcept .

:IAMConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Identity and Access Management (IAM)"@en ;
    schema:description
        "Traditional IAM infrastructure designed for human users and static service accounts. Identified by Jonathan Jaffe as architecturally mismatched to agentic systems: insufficient for unique per-agent identity, multi-hop delegation chains, and fine-grained attribute-based policy at the scale of thousands of concurrent agents."@en ;
    owl:sameAs wd:Q485024 ;
    skos:broader :SecurityConcept .

:RDFConcept
    a skos:Concept, schema:DefinedTerm ;
    schema:name "Resource Description Framework (RDF)"@en ;
    schema:description
        "W3C standard data model for machine-readable knowledge representation as subject-predicate-object triples. The foundation for agent profile documents: encoding identity, delegation relationships, capability declarations, and provenance in a format that enables automated reasoning."@en ;
    owl:sameAs wd:Q54871 ;
    skos:broader :SemanticWebConcept .

:SecurityConcept
    a skos:Concept ;
    schema:name "Information Security"@en .

:DigitalIdentityConcept
    a skos:Concept ;
    schema:name "Digital Identity"@en .

:DataManagementConcept
    a skos:Concept ;
    schema:name "Data Management"@en .

:SemanticWebConcept
    a skos:Concept ;
    schema:name "Semantic Web"@en .


# ─────────────────────────────────────────────────────────────────────────────
# The Five Pillars — as structured schema:HowToStep entities
# ─────────────────────────────────────────────────────────────────────────────

:AgentGovernanceFramework
    a schema:HowTo ;
    schema:name "SSI-Based AI Agent Governance Framework"@en ;
    schema:description
        "A five-pillar framework for governing AI agents at scale using Self-Sovereign Identity primitives: establishing verifiable agent identity via HTTP URIs, describing agents and delegation chains in RDF profile documents, authenticating via WebID-TLS/NetID-TLS/OAuth, authorizing via ABAC, and scoping all data space operations to verified identity with full provenance."@en ;
    schema:step
        :Pillar1AgentIdentity ,
        :Pillar2AgentProfiles ,
        :Pillar3Authentication ,
        :Pillar4Authorization ,
        :Pillar5DataSpaceAccess .

:Pillar1AgentIdentity
    a schema:HowToStep ;
    schema:name "Pillar 1 — Agent Identity: Hyperlinks as Identifiers"@en ;
    schema:position 1 ;
    schema:text
        "Assign each AI agent a dereferenceable HTTP URI as its stable, globally unique identifier. Embed this URI in the agent's X.509 certificate Subject Alternative Name field. The URI resolves to the agent's public profile document, enabling external verification. Identity is portable across platforms, tools, and organizational contexts."@en ;
    schema:about :AgentIdentityConcept ;
    prov:used :WebIDConcept, :X509Concept .

:Pillar2AgentProfiles
    a schema:HowToStep ;
    schema:name "Pillar 2 — Agent Profiles: RDF Documents with On-Behalf-Of Relationships"@en ;
    schema:position 2 ;
    schema:text
        "Publish a machine-readable RDF profile document for each agent, using shared ontology terms to encode its identity, role, capabilities, and delegation chain. Critically, include prov:actedOnBehalfOf and acl:delegates relationships linking the agent to its authorizing human user, creating a machine-computable chain of authority suitable for automated reasoning."@en ;
    schema:about :AgentProfileConcept ;
    prov:used :RDFConcept, :DelegationConcept .

:Pillar3Authentication
    a schema:HowToStep ;
    schema:name "Pillar 3 — Authentication: WebID-TLS, NetID-TLS, and OAuth"@en ;
    schema:position 3 ;
    schema:text
        "Authenticate agents using battle-tested protocols. In WebID-TLS and NetID-TLS, the agent presents its X.509 certificate during the TLS handshake; the server dereferences the certificate subject URI to retrieve the agent's profile document and matches the public key — cryptographic proof of identity with no central authority required. OAuth 2.0 handles delegated access flows for third-party integrations."@en ;
    schema:about :AuthenticationConcept ;
    prov:used :WebIDConcept, :NetIDTlsConcept, :OAuthConcept .

:Pillar4Authorization
    a schema:HowToStep ;
    schema:name "Pillar 4 — Authorization: Attribute-Based Access Control (ABAC)"@en ;
    schema:position 4 ;
    schema:text
        "Define and enforce conditional permissions using ABAC, evaluated against verified agent attributes: identity URI, role, delegating user identity, resource classification, and request context. Implement resource-level ACLs using W3C Web Access Control with acl:Read, acl:Write, and acl:Control. Agent authority is strictly bounded by the authorizing user's own scope — no privilege escalation via delegation is structurally possible."@en ;
    schema:about :AuthorizationConcept ;
    prov:used :DelegationConcept, :AgentIdentityConcept .

:Pillar5DataSpaceAccess
    a schema:HowToStep ;
    schema:name "Pillar 5 — Data Space Read & Write: Identity-Scoped Access with Provenance"@en ;
    schema:position 5 ;
    schema:text
        "Scope all agent interactions with data spaces (SPARQL endpoints, WebDAV stores, REST APIs, graph databases) to the agent's verified identity and delegation chain. Every write operation must carry prov:wasAttributedTo and prov:wasGeneratedBy triples recording the agent's URI and authorizing user URI. Named graphs isolate each agent's workspace, preventing cross-agent data bleed and enabling per-agent audit at the named-graph level."@en ;
    schema:about :DataSpaceAccessConcept ;
    prov:used :ProvenanceConcept, :AuthorizationConcept .


# ─────────────────────────────────────────────────────────────────────────────
# Key Governance Gaps Addressed
# (from Anthropic's identified open challenges, mapped to SSI remedies)
# ─────────────────────────────────────────────────────────────────────────────

:Gap_AgentAccountability
    a schema:DefinedTerm ;
    schema:name "Gap: Agent Accountability at Scale"@en ;
    schema:description
        "Current containment models provide logs but lack verifiable per-agent identity. Without a URI-based identity and X.509 binding, audit trails cannot reliably attribute actions to specific agents."@en ;
    schema:potentialAction :Pillar1AgentIdentity .

:Gap_MultiAgentTrustEscalation
    a schema:DefinedTerm ;
    schema:name "Gap: Multi-Agent Trust Escalation"@en ;
    schema:description
        "Structured sub-agent outputs are treated as higher-trust than raw tool results, enabling trust escalation without structural enforcement. Identified by Anthropic as an open challenge. Addressed by delegation chain verification: agent authority is bounded by the authorizing user's scope, enforced at the profile and ABAC layers."@en ;
    schema:potentialAction :Pillar2AgentProfiles, :Pillar4Authorization .

:Gap_PersistentMemoryPoisoning
    a schema:DefinedTerm ;
    schema:name "Gap: Persistent Memory Poisoning"@en ;
    schema:description
        "Growing session state (CLAUDE.md files, product memory) creates persistence mechanisms for injected malicious content. Addressed by named graph isolation per agent identity and mandatory write provenance — poisoned content is attributable and compartmentalized."@en ;
    schema:potentialAction :Pillar5DataSpaceAccess .

:Gap_CrossPlatformPermissionPortability
    a schema:DefinedTerm ;
    schema:name "Gap: Cross-Platform Permission Portability"@en ;
    schema:description
        "Current agent permissions are per-deployment and ad-hoc. ABAC policies tied to a portable agent URI identity travel with the agent across deployments, platforms, and organizational contexts."@en ;
    schema:potentialAction :Pillar4Authorization, :Pillar1AgentIdentity .

:Gap_DelegationTransparency
    a schema:DefinedTerm ;
    schema:name "Gap: On-Behalf-Of Delegation Transparency"@en ;
    schema:description
        "In current deployments, agent delegation to act on a user's behalf is implicit and not machine-readable. RDF profile documents with prov:actedOnBehalfOf and acl:delegates predicates make delegation explicit, verifiable, and suitable for automated reasoning."@en ;
    schema:potentialAction :Pillar2AgentProfiles .


# ─────────────────────────────────────────────────────────────────────────────
# Key Quotes (as schema:Quotation)
# ─────────────────────────────────────────────────────────────────────────────

:Quote_JaffeAgentIdentity
    a schema:Quotation ;
    schema:text
        "Every agent needs to have an identity… you need a way to control policy for all of these agents in a much more complex way than current identity and access management systems do."@en ;
    schema:spokenByCharacter :JonathanJaffe ;
    schema:citation :JaffeSecurityArticle .

:Quote_JaffeAutomation
    a schema:Quotation ;
    schema:text
        "Automation is the only way you can deal with the scale of what's coming at us now."@en ;
    schema:spokenByCharacter :JonathanJaffe ;
    schema:citation :JaffeSecurityArticle .

:Quote_AnthropicContainmentPrinciple
    a schema:Quotation ;
    schema:text
        "Design for containment at the environment layer first, then steer behavior at the model layer — deterministic boundaries catch failures that probabilistic defenses miss."@en ;
    schema:spokenByCharacter :Anthropic ;
    schema:citation :AnthropicContainmentArticle .

:Quote_Idehen_IdentityControl
    a schema:Quotation ;
    schema:text
        "Identity control means having control over critical claims that constitute how one is described and recognized… enabling individuality at scale, privacy calibration, and context-specific identification."@en ;
    schema:spokenByCharacter :KingsleyIdehen ;
