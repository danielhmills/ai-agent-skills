# ============================================================================
# FAQ SECTION (12 Questions)
# ============================================================================

:faqSection a schema:FAQPage ;
    schema:name "Frequently Asked Questions — The Semantic Medallion"@en ;
    schema:mainEntity :q1, :q2, :q3, :q4, :q5, :q6, :q7, :q8, :q9, :q10, :q11, :q12 ;
    schema:isPartOf :analysis .

:q1 a schema:Question ;
    schema:name "What is the Semantic Medallion?"@en ;
    schema:text "What is the Semantic Medallion?"@en ;
    schema:acceptedAnswer :a1 .

:a1 a schema:Answer ;
    schema:text "The Semantic Medallion is an augmentation of the traditional medallion data architecture (Bronze → Silver → Gold) where the Gold layer becomes an RDF knowledge graph instead of clean tabular data. DCAT catalog metadata is woven into the same graph, creating a self-describing knowledge graph-powered data catalog."@en ;
    schema:isPartOf :faqSection .

:q2 a schema:Question ;
    schema:name "How does the Bronze layer differ from traditional medallion Bronze?"@en ;
    schema:text "How does the Bronze layer differ from traditional medallion Bronze?"@en ;
    schema:acceptedAnswer :a2 .

:a2 a schema:Answer ;
    schema:text "In the Semantic Medallion, the Bronze layer functions identically to traditional medallion — it harvests raw data from source systems without transformation. The difference emerges at Silver, where IRIs are minted instead of just cleaning data."@en ;
    schema:isPartOf :faqSection .

:q3 a schema:Question ;
    schema:name "What is IRI minting and why is it important?"@en ;
    schema:text "What is IRI minting and why is it important?"@en ;
    schema:acceptedAnswer :a3 .

:a3 a schema:Answer ;
    schema:text "IRI minting is the process of assigning a stable globally unique Internationalized Resource Identifier to every entity at the Silver layer. It is critical because it makes entities referenceable across systems — without stable IRIs, linking customer records from CRM, ERP, and billing systems would require fragile key matching. IRIs are the foundation of linked data."@en ;
    schema:isPartOf :faqSection .

:q4 a schema:Question ;
    schema:name "What role do OTTR templates play?"@en ;
    schema:text "What role do OTTR templates play?"@en ;
    schema:acceptedAnswer :a4 .

:a4 a schema:Answer ;
    schema:text "OTTR (Reasonable Ontology Templates) provides a declarative template language for mapping structured data to RDF. Using stOTTR (string OTTR) syntax, templates define how DataFrame columns map to ontology classes and properties. A single template can transform millions of Silver-layer rows into RDF triples in a consistent repeatable way."@en ;
    schema:isPartOf :faqSection .

:q5 a schema:Question ;
    schema:name "How does maplib simplify the DataFrame-to-RDF transformation?"@en ;
    schema:text "How does maplib simplify the DataFrame-to-RDF transformation?"@en ;
    schema:acceptedAnswer :a5 .

:a5 a schema:Answer ;
    schema:text "maplib is a Python library that accepts a pandas DataFrame, an OTTR template, and a result RDF container, then executes the mapping in a single call: `maplib.map(dataframe, template, result_container)`. This reduces what would otherwise be hundreds of lines of triple-construction code to four lines of Python."@en ;
    schema:isPartOf :faqSection .

:q6 a schema:Question ;
    schema:name "What is DCAT and why is it used in the Semantic Medallion?"@en ;
    schema:text "What is DCAT and why is it used in the Semantic Medallion?"@en ;
    schema:acceptedAnswer :a6 .

:a6 a schema:Answer ;
    schema:text "DCAT (Data Catalog Vocabulary) is a W3C standard for describing data catalogs, datasets, distributions, and data services in RDF. In the Semantic Medallion, each medallion layer receives DCAT descriptions — the catalog metadata and the actual data coexist in the same graph, making the catalog self-describing rather than a separate metadata store."@en ;
    schema:isPartOf :faqSection .

:q7 a schema:Question ;
    schema:name "How does PROV-O enhance the catalog?"@en ;
    schema:text "How does PROV-O enhance the catalog?"@en ;
    schema:acceptedAnswer :a7 .

:a7 a schema:Answer ;
    schema:text "PROV-O (Provenance Ontology) tracks data lineage — where each record came from, which system generated it, and what transformations were applied. In the catalog, provenance links connect customer facts back to their source systems, answering questions like 'Which CRM and billing records contributed to this customer view?'"@en ;
    schema:isPartOf :faqSection .

:q8 a schema:Question ;
    schema:name "What kinds of queries does the knowledge graph catalog enable?"@en ;
    schema:text "What kinds of queries does the knowledge graph catalog enable?"@en ;
    schema:acceptedAnswer :a8 .

:a8 a schema:Answer ;
    schema:text "The knowledge graph catalog enables three categories of queries: (1) entity lookup — retrieve all facts about a single entity; (2) provenance tracing — list all source systems contributing to a record; (3) cross-domain pattern detection — find entities that match conditions spanning multiple domains, such as customers with both active contracts and open billing issues. These cross-domain queries are particularly powerful because they traverse relationships that would require complex joins across siloed SQL databases."@en ;
    schema:isPartOf :faqSection .

:q9 a schema:Question ;
    schema:name "How does the Semantic Medallion handle entity resolution?"@en ;
    schema:text "How does the Semantic Medallion handle entity resolution?"@en ;
    schema:acceptedAnswer :a9 .

:a9 a schema:Answer ;
    schema:text "Entity resolution happens naturally through IRI alignment. Because every entity receives a globally unique IRI at the Silver layer, records from different source systems that refer to the same real-world entity are linked to the same IRI. The Gold layer's ontology then connects these IRIs across domains, enabling graph-based deduplication and identity resolution."@en ;
    schema:isPartOf :faqSection .

:q10 a schema:Question ;
    schema:name "What is SHACL and how does it fit?"@en ;
    schema:text "What is SHACL and how does it fit?"@en ;
    schema:acceptedAnswer :a10 .

:a10 a schema:Answer ;
    schema:text "SHACL (Shapes Constraint Language) is a W3C standard for validating RDF data against shape conditions. In the Semantic Medallion architecture, SHACL shapes can be applied to the Gold layer to enforce data quality rules — ensuring every Customer has required properties, contracts have valid statuses, and data sources are properly typed."@en ;
    schema:isPartOf :faqSection .

:q11 a schema:Question ;
    schema:name "What are the key lessons from implementing the Semantic Medallion?"@en ;
    schema:text "What are the key lessons from implementing the Semantic Medallion?"@en ;
    schema:acceptedAnswer :a11 .

:a11 a schema:Answer ;
    schema:text "Three key lessons: (1) Start with IRIs early — minting identifiers at the Silver layer pays compounding dividends as more systems connect. (2) Design ontologies iteratively — begin with a minimal shared ontology and expand as new use cases emerge rather than attempting a complete model upfront. (3) The medallion is about semantic enrichment layers — Bronze has no semantics, Silver has local semantics, Gold has global semantics. Each layer adds meaning rather than just cleanliness."@en ;
    schema:isPartOf :faqSection .

:q12 a schema:Question ;
    schema:name "How does the Semantic Medallion compare to a traditional data catalog?"@en ;
    schema:text "How does the Semantic Medallion compare to a traditional data catalog?"@en ;
    schema:acceptedAnswer :a12 .

:a12 a schema:Answer ;
    schema:text "Traditional data catalogs describe where data lives (table names, column schemas, storage locations) but do not describe how data connects across systems. A knowledge graph-powered catalog captures both — DCAT metadata describes the datasets while RDF relationships connect customer entities to their source systems, contracts, and issues. The catalog becomes queryable in the same SPARQL endpoint as the data it describes."@en ;
    schema:isPartOf :faqSection .

# ============================================================================
# GLOSSARY SECTION (10 Terms)
# ============================================================================

:glossarySection a schema:DefinedTermSet, skos:ConceptScheme ;
    schema:name "Glossary — Semantic Medallion"@en ;
    schema:description "Key terminology from the Semantic Medallion architecture and knowledge graph-powered data catalog ecosystem."@en ;
    schema:hasDefinedTerm :termMedallionArchitecture, :termIRIMinting, :termOTTR, :termMaplib, :termDCAT,
        :termPROVO, :termSHACL, :termKnowledgeGraph, :termSPARQL, :termSemanticEnrichment ;
    schema:isPartOf :analysis .

:termMedallionArchitecture a schema:DefinedTerm, skos:Concept ;
    schema:name "Medallion Architecture"@en ;
    schema:termCode "medallion-architecture" ;
    schema:description "A data architecture pattern organizing data into Bronze (raw), Silver (cleaned/enriched), and Gold (analytics-ready) layers. The Semantic Medallion redefines Gold as an RDF knowledge graph."@en ;
    schema:inDefinedTermSet :glossarySection .

:termIRIMinting a schema:DefinedTerm, skos:Concept ;
    schema:name "IRI Minting"@en ;
    schema:termCode "iri-minting" ;
    schema:description "The process of assigning stable globally unique Internationalized Resource Identifiers to entities, enabling cross-system linking and resolution in linked data architectures."@en ;
    schema:inDefinedTermSet :glossarySection .

:termOTTR a schema:DefinedTerm, skos:Concept ;
    schema:name "OTTR (Reasonable Ontology Templates)"@en ;
    schema:termCode "ottr" ;
    schema:description "A framework for template-based ontology mapping. stOTTR (string syntax) defines reusable templates that declaratively map structured data columns to RDF ontology classes and properties."@en ;
    schema:inDefinedTermSet :glossarySection .

:termMaplib a schema:DefinedTerm, skos:Concept ;
    schema:name "maplib"@en ;
    schema:termCode "maplib" ;
    schema:description "A Python library for DataFrame-to-RDF transformation using OTTR templates. Enables a single function call to convert pandas DataFrames into RDF knowledge graphs."@en ;
    schema:inDefinedTermSet :glossarySection .

:termDCAT a schema:DefinedTerm, skos:Concept ;
    schema:name "DCAT (Data Catalog Vocabulary)"@en ;
    schema:termCode "dcat" ;
    schema:description "A W3C standard RDF vocabulary for describing data catalogs, datasets, distributions, and data services. Used in the Semantic Medallion to weave catalog metadata into the knowledge graph."@en ;
    schema:inDefinedTermSet :glossarySection .

:termPROVO a schema:DefinedTerm, skos:Concept ;
    schema:name "PROV-O (Provenance Ontology)"@en ;
    schema:termCode "prov-o" ;
    schema:description "A W3C standard ontology for representing provenance information — tracking who generated data, what sources it came from, and what transformations were applied."@en ;
    schema:inDefinedTermSet :glossarySection .

:termSHACL a schema:DefinedTerm, skos:Concept ;
    schema:name "SHACL (Shapes Constraint Language)"@en ;
    schema:termCode "shacl" ;
    schema:description "A W3C standard for validating RDF graphs against shape conditions, enabling data quality enforcement in knowledge graph systems."@en ;
    schema:inDefinedTermSet :glossarySection .

:termKnowledgeGraph a schema:DefinedTerm, skos:Concept ;
    schema:name "Knowledge Graph"@en ;
    schema:termCode "knowledge-graph" ;
    schema:description "A graph-structured representation of data where entities are nodes connected by typed relationships, enabling semantic querying and inference beyond what relational databases support."@en ;
    schema:inDefinedTermSet :glossarySection .

:termSPARQL a schema:DefinedTerm, skos:Concept ;
    schema:name "SPARQL"@en ;
    schema:termCode "sparql" ;
    schema:description "SPARQL Protocol and RDF Query Language — the W3C standard query language for RDF knowledge graphs, analogous to SQL for relational databases but designed for graph pattern matching."@en ;
    schema:inDefinedTermSet :glossarySection .

:termSemanticEnrichment a schema:DefinedTerm, skos:Concept ;
    schema:name "Semantic Enrichment"@en ;
    schema:termCode "semantic-enrichment" ;
    schema:description "The progressive addition of meaning to data as it moves through the medallion layers: none at Bronze, local at Silver (IRIs within a domain), global at Gold (cross-domain ontology linking)."@en ;
    schema:inDefinedTermSet :glossarySection .

# ============================================================================
# HOW-TO SECTION (7 Steps)
# ============================================================================

:howtoSection a schema:HowTo ;
    schema:name "How to Build a Semantic Medallion Pipeline"@en ;
    schema:description "Step-by-step guide to implementing a knowledge graph-powered data catalog using the Semantic Medallion architecture."@en ;
    schema:step :step1, :step2, :step3, :step4, :step5, :step6, :step7 ;
    schema:isPartOf :analysis .

:step1 a schema:HowToStep ;
    schema:name "Step 1: Harvest Raw Data into the Bronze Layer"@en ;
    schema:text "Ingest raw data from all source systems — CRM, ERP, billing, support — into the Bronze layer. Apply no transformations. Preserve original formats and timestamps. This is raw material only."@en ;
    schema:position 1 ;
    schema:isPartOf :howtoSection .

:step2 a schema:HowToStep ;
    schema:name "Step 2: Mint Stable IRIs at the Silver Layer"@en ;
    schema:text "For every entity in the Bronze data, create a stable globally unique IRI. Choose a consistent IRI pattern (e.g., https://company.example/entity/{type}/{id}). Store the IRI-to-record mapping. This is the most critical step — IRIs are the foundation for all downstream linking."@en ;
    schema:position 2 ;
    schema:isPartOf :howtoSection .

:step3 a schema:HowToStep ;
    schema:name "Step 3: Design a Shared Ontology"@en ;
    schema:text "Define the core classes (e.g., Customer, Contract, DataSource) and properties (e.g., hasContract, wasDerivedFrom) that span your business domains. Start minimal — a small shared ontology that captures cross-domain relationships. Expand iteratively as new use cases emerge. Document every class and property with rdfs:label and rdfs:comment."@en ;
    schema:position 3 ;
    schema:isPartOf :howtoSection .

:step4 a schema:HowToStep ;
    schema:name "Step 4: Author OTTR Templates"@en ;
    schema:text "Write stOTTR templates that map Silver-layer DataFrame columns to your shared ontology. Each template defines how a row becomes RDF: which column maps to which class, which columns become properties, and how IRIs are constructed. Templates make the mapping declarative and reusable."@en ;
    schema:position 4 ;
    schema:isPartOf :howtoSection .

:step5 a schema:HowToStep ;
    schema:name "Step 5: Transform to RDF with maplib"@en ;
    schema:text "Load Silver-layer DataFrames into pandas. Call maplib.map(dataframe, template, result_container) for each template. The library executes the OTTR mapping and populates the RDF graph. Validate the output RDF syntax before proceeding."@en ;
    schema:position 5 ;
    schema:isPartOf :howtoSection .

:step6 a schema:HowToStep ;
    schema:name "Step 6: Weave in DCAT and PROV-O Metadata"@en ;
    schema:text "Describe each medallion layer as a DCAT Dataset with distributions and data services. Add PROV-O provenance links connecting Gold-layer entities back to their source systems. The catalog metadata now lives alongside the data in the same RDF graph."@en ;
    schema:position 6 ;
    schema:isPartOf :howtoSection .

:step7 a schema:HowToStep ;
    schema:name "Step 7: Query and Validate"@en ;
    schema:text "Load the RDF into a SPARQL-capable triplestore (e.g., Virtuoso). Run validation queries to confirm entity counts and relationship integrity. Apply SHACL shapes for data quality enforcement. Then query your knowledge graph catalog — start with entity lookup, progress to provenance tracing, and finally cross-domain pattern detection."@en ;
    schema:position 7 ;
    schema:isPartOf :howtoSection .

