    "http://schema.org/isPartOf": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#faqSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "What is R2RML and why is it important?"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "What is R2RML and why is it important?"
      }
    ]
  },
  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#a6",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Answer: What are Quad Maps in Virtuoso?..."
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Quad Maps are Virtuoso's internal representation of R2RML mappings — they define how SPARQL graph patterns translate to SQL queries against virtual tables. The R2RML_MAKE_QM_FROM_G function converts declarative R2RML Turtle mappings into optimized Quad Maps that Virtuoso's SPARQL engine uses at query time. This is what makes SPARQL queries executable against remote relational tables without data movement."
      }
    ]
  },
  {
