  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#capSemanticEnrichment",
    "@type": [
      "http://schema.org/ActionAccessSpecification"
    ],
