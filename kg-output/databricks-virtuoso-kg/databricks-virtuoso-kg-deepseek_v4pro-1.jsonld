      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A knowledge graph constructed over existing relational data without physical data movement — using virtual database attachment to expose tables, R2RML to define semantic mappings, and SPARQL for graph querying."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Virtual Knowledge Graph (VKG)"
      }
    ]
  },
