  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#sparqlTopRatedFranchises",
    "@type": [
      "http://schema.org/SoftwareSourceCode"
    ],
    "http://schema.org/codeSampleType": [
      {
        "@value": "text/x-html+tr"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Customer satisfaction metrics — averages review ratings per franchise for a quality monitoring dashboard."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Dashboard: Top Rated Franchises (Customer Satisfaction)"
      }
    ],
    "http://schema.org/potentialAction": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#actionsparqlTopRatedFranchises"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "SPARQL"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#demoSparqlEndpoint"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "PREFIX : <http://www.databricks.com/bakehouse#>\n\nSELECT\n?franchiseName\n?city\n(COUNT(?review) AS ?reviewCount)\n(ROUND(AVG(?rating))*10/10 AS ?avgRating)\nWHERE {\n  GRAPH <https://linkeddata.uriburner.com/DAV/demos/daas/databricks-virtuoso-kg-deepseek_v4pro-1.ttl> {\n  \n    ?review a :Review;\n     :franchise ?franchise;\n     :rating ?rating.\n    ?franchise :city ?city.\n    OPTIONAL { ?franchise :franchiseName ?franchiseName. }\n  \n  }\n}\nGROUP BY ?franchiseName ?city\nHAVING (COUNT(?review) >= 3)\nORDER BY DESC(?avgRating)\nLIMIT 10"
      }
    ]
  },
  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#actionsparqlEntityTypes",
    "@type": [
      "http://schema.org/SearchAction"
    ],
    "http://schema.org/target": [
      {
        "@value": "http://demo.openlinksw.com/sparql?default-graph-uri=&qtxt=SELECT+*%0D%0AFROM+%3Chttp%3A%2F%2Fdemo.openlinksw.com%2Fdatabricks-bakehouse-r2rml%23%3E%0D%0AWHERE%0D%0A%7B%0D%0A++%3Fs+a+%3Fo%0D%0A%7D%0D%0ALIMIT+10"
      }
    ]
  },
  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#a9",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Answer: What Databricks components are required?..."
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "You need: (1) a Databricks SQL warehouse (Serverless, Pro, or Classic) to provide the ODBC endpoint; (2) the Databricks ODBC Driver installed on the Virtuoso host; (3) a Personal Access Token for authentication; and (4) the workspace Host and HTTP Path for the SQL warehouse. The public samples.bakehouse dataset provides the example tables — your own Databricks catalogs and schemas work the same way."
      }
    ]
  },
