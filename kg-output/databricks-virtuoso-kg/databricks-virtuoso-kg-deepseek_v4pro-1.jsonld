      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Connect to the Data Source"
      }
    ],
    "http://schema.org/position": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Find databricks_odbc in the External Data Sources list, click Connect, supply the username (token) and password (personal access token), and establish the ODBC connection from Virtuoso to the Databricks SQL warehouse."
      }
    ]
  },
