  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#aiAgentFriendlyKG",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A knowledge graph designed for consumption by AI agents — featuring dereferenceable entity URIs, machine-readable RDF representations, SPARQL endpoints for structured querying, and navigable entity relationships. The Databricks-Virtuoso pipeline produces such a graph: an AI agent can follow entity links, execute SPARQL queries, and retrieve structured context without custom API integration."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "AI Agent-Friendly Knowledge Graph"
      }
    ]
  },
  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#sparqlConstructVisualization",
    "@type": [
      "http://schema.org/SoftwareSourceCode"
    ],
    "http://schema.org/codeSampleType": [
      {
        "@value": "text/x-html-nice-turtle"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "SPARQL CONSTRUCT extracting the Transaction-Franchise-City subgraph for interactive node-link visualization in SPARQLWorks."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "CONSTRUCT for Graph Visualization (SPARQLWorks)"
      }
    ],
    "http://schema.org/potentialAction": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#actionsparqlConstructVisualization"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "SPARQL"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#demoSparqlEndpoint"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "PREFIX : <http://www.databricks.com/bakehouse#>\n\nCONSTRUCT\n{\n  ?transaction a :Transaction;\n   :franchise ?franchise;\n   :totalPrice ?totalPrice.\n\n  ?franchise :city ?franchiseCity.\n}\nWHERE\n{\n  GRAPH <https://linkeddata.uriburner.com/DAV/demos/daas/databricks-virtuoso-kg-deepseek_v4pro-1.ttl>\n  {\n    ?transaction a :Transaction;\n     :franchise ?franchise;\n     :totalPrice ?totalPrice.\n\n    ?franchise :city ?franchiseCity.\n  }\n}\nLIMIT 100"
      }
    ]
