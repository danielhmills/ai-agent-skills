  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#looselyCoupledSemanticLayer",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A semantic enrichment layer that sits atop existing data platforms without tight coupling — replacing ETL-driven data copying with standards-based virtualization. The knowledge graph is an overlay, not a replacement or another silo."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Loosely Coupled Semantic Layer"
      }
    ]
  },
  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#analysis",
    "@type": [
      "http://schema.org/CreativeWork",
      "http://schema.org/TechArticle"
    ],
    "http://schema.org/about": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#virtualKnowledgeGraphConcept"
      },
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#databricksPlatform"
      },
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#virtuosoPlatform"
      },
      {
        "@id": "http://dbpedia.org/resource/Semantic_Web"
      },
      {
        "@id": "http://dbpedia.org/resource/Knowledge_graph"
      }
    ],
    "http://schema.org/abstract": [
      {
        "@language": "en",
        "@value": "A step-by-step guide demonstrating how to unlock machine-computable entity relationships across existing Databricks data without migration, duplication, or platform lock-in — using RDF, SPARQL, R2RML, and Virtuoso's Virtual Database to create an AI Agent-friendly Knowledge Graph deployed on the Semantic Web."
      }
    ],
    "http://schema.org/articleBody": [
      {
        "@language": "en",
        "@value": "Modern AI and analytics need graph reasoning capabilities — the ability to traverse relationships and discover patterns across connected data — but most enterprise data sits in relational warehouses where relationships rely on implicit foreign keys. This guide shows how to bridge that gap using open W3C standards: RDF for entity relationships, SPARQL for graph querying, and R2RML for exposing relational data as graphs. Hyperlinks (IRIs) serve as globally unique identifiers enabling disparate systems to be connected and reasoned over as a whole. The result is a Knowledge Graph that extends beyond the boundaries of any single database, platform, or application."
      }
    ],
    "http://schema.org/author": [
      {
        "@id": "https://github.com/danielhmills#this"
      }
    ],
    "http://schema.org/dateModified": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-17"
      }
    ],
    "http://schema.org/datePublished": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-09"
      }
    ],
