    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Data Platform"
      }
    ]
  },
  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#sparqlRevenueByCity",
    "@type": [
      "http://schema.org/SoftwareSourceCode"
    ],
    "http://schema.org/codeSampleType": [
      {
        "@value": "text/x-html+tr"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Geographic revenue breakdown — aggregates totalPrice by franchise city for a regional performance dashboard."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Dashboard: Revenue by City (Geographic Distribution)"
      }
    ],
    "http://schema.org/potentialAction": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#actionsparqlRevenueByCity"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "SPARQL"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#demoSparqlEndpoint"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "PREFIX : <http://www.databricks.com/bakehouse#>\n\nSELECT\n?city\n(COUNT(DISTINCT ?transaction) AS ?orderCount)\n(SUM(?totalPrice) AS ?revenue)\n(ROUND(AVG(?totalPrice)) AS ?avgOrderValue)\nWHERE {\n  GRAPH <https://linkeddata.uriburner.com/DAV/demos/daas/databricks-virtuoso-kg-deepseek_v4pro-1.ttl> {\n  \n    ?transaction a :Transaction;\n     :franchise ?franchise;\n     :totalPrice ?totalPrice.\n    ?franchise :city ?city.\n  \n  }\n}\nGROUP BY ?city\nORDER BY DESC(?revenue)"
      }
    ]
  },
  {
