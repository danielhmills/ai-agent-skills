      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "AI Agent-Friendly Knowledge Graph"
      }
    ]
  },
  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#termLinkedData",
    "@type": [
      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A method of publishing structured data on the web using HTTP URIs, RDF, and content negotiation — enabling entities to be interlinked across systems and consumed by both humans and machines."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Linked Data"
      }
    ]
  },
  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#capZeroMovement",
    "@type": [
      "http://schema.org/ActionAccessSpecification"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Virtuoso's Virtual Database attaches Databricks tables via ODBC as virtual references — no ETL, no duplication, no stale copies."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Zero data movement"
      }
    ]
  },
  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#a10",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Answer: How does this compare to traditional ETL-based knowledge gra..."
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Traditional ETL-based approaches: extract data from source, transform to RDF, load into a triplestore — creating a copy that must be kept in sync. The virtual approach: no extraction, no transformation pipeline, no load step, no stale copies. R2RML mappings define the semantic model declaratively; SPARQL queries execute against live data. Changes in Databricks tables are immediately visible in SPARQL results. The trade-off is query latency versus data freshness — the virtual approach prioritizes freshness and simplicity over raw graph traversal speed."
      }
    ]
  },
