        "@value": "Semantic enrichment"
      }
    ]
  },
  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#sparqlSupplierProductFlow",
    "@type": [
      "http://schema.org/SoftwareSourceCode"
    ],
    "http://schema.org/codeSampleType": [
      {
        "@value": "text/x-html+tr"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Supply chain visibility — traces supplier ingredients to the franchises that use them for a supply chain dashboard."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Dashboard: Supplier-Ingredient-Franchise Product Flow"
      }
    ],
    "http://schema.org/potentialAction": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#actionsparqlSupplierProductFlow"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "SPARQL"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#demoSparqlEndpoint"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "PREFIX : <http://www.databricks.com/bakehouse#>\n\nSELECT\n?supplierName\n?ingredientName\n(COUNT(DISTINCT ?franchise) AS ?franchisesServed)\nWHERE {\n  GRAPH <https://linkeddata.uriburner.com/DAV/demos/daas/databricks-virtuoso-kg-deepseek_v4pro-1.ttl> {\n  \n    ?supply a :SupplyContract;\n     :supplier ?supplier;\n     :ingredient ?ingredient;\n     :franchise ?franchise.\n    ?supplier :supplierName ?supplierName.\n    ?ingredient :ingredientName ?ingredientName.\n  \n  }\n}\nGROUP BY ?supplierName ?ingredientName\nORDER BY DESC(?franchisesServed)\nLIMIT 15"
      }
    ]
  },
  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#hyperlinkBasedEntityIdentity",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The use of IRIs (Internationalized Resource Identifiers) as globally unique, dereferenceable entity identifiers — enabling entities from different systems (Databricks tables, external reference data, other knowledge graphs) to be linked and reasoned over as a single connected graph."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Hyperlink-Based Entity Identity"
      }
    ]
  },
