  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#sparqlTopCustomers",
    "@type": [
      "http://schema.org/SoftwareSourceCode"
    ],
    "http://schema.org/codeSampleType": [
      {
        "@value": "text/x-html+tr"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Customer value analysis — ranks customers by total spend across all their transactions for a CRM dashboard."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Dashboard: Top 10 Customers by Total Spend"
      }
    ],
    "http://schema.org/potentialAction": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#actionsparqlTopCustomers"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "SPARQL"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#demoSparqlEndpoint"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "PREFIX : <http://www.databricks.com/bakehouse#>\n\nSELECT\n?customerName\n(COUNT(DISTINCT ?transaction) AS ?purchaseCount)\n(SUM(?totalPrice) AS ?lifetimeValue)\n(ROUND(SUM(?totalPrice)/COUNT(DISTINCT ?transaction)) AS ?avgPurchaseValue)\nWHERE {\n  GRAPH <https://linkeddata.uriburner.com/DAV/demos/daas/databricks-virtuoso-kg-deepseek_v4pro-1.ttl> {\n  \n    ?transaction a :Transaction;\n     :customer ?customer;\n     :totalPrice ?totalPrice.\n    ?customer :customerName ?customerName.\n  \n  }\n}\nGROUP BY ?customerName\nORDER BY DESC(?lifetimeValue)\nLIMIT 10"
      }
    ]
  },
  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#contentNegotiationConcept",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "An HTTP mechanism where the server inspects the client's Accept header to determine the response format — returning an HTML description page for browsers and RDF (Turtle, JSON-LD, RDF/XML) for semantic agents and RDF clients."
      }
    ],
    "http://schema.org/name": [
      {
