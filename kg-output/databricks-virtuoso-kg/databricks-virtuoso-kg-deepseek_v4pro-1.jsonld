  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#sparqlRevenueByFranchise",
    "@type": [
      "http://schema.org/SoftwareSourceCode"
    ],
    "http://schema.org/codeSampleType": [
      {
        "@value": "text/x-html+tr"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "SPARQL SELECT with SUM aggregation joining Transaction and Franchise tables via the :franchise property, grouped by franchise and city."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Revenue by Franchise (Cross-Table SPARQL Join)"
      }
    ],
    "http://schema.org/potentialAction": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#actionsparqlRevenueByFranchise"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "SPARQL"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#demoSparqlEndpoint"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "PREFIX : <http://www.databricks.com/bakehouse#>\n\nSELECT\n?franchise\n?franchiseCity\nSUM(?totalPrice) as ?revenue\nWHERE {\n  GRAPH <https://linkeddata.uriburner.com/DAV/demos/daas/databricks-virtuoso-kg-deepseek_v4pro-1.ttl> {\n  \n    ?transaction a :Transaction;\n     :franchise ?franchise;\n     :totalPrice ?totalPrice.\n  \n    ?franchise :city ?franchiseCity.\n  \n  }\n}\nGROUP BY ?franchise ?franchiseCity\nORDER BY DESC(?revenue)\nLIMIT 10"
      }
    ]
  },
