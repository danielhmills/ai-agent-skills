  {
    "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#sparqlOrderSizeDistribution",
    "@type": [
      "http://schema.org/SoftwareSourceCode"
    ],
    "http://schema.org/codeSampleType": [
      {
        "@value": "text/x-html+tr"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Revenue segmentation analysis — buckets transactions by value range for a financial performance dashboard."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Dashboard: Order Size Distribution (Revenue Segmentation)"
      }
    ],
    "http://schema.org/potentialAction": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#actionsparqlOrderSizeDistribution"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "SPARQL"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "https://community.openlinksw.com/t/from-databricks-tables-to-a-virtual-knowledge-graph-with-virtuoso/6293#demoSparqlEndpoint"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "PREFIX : <http://www.databricks.com/bakehouse#>\n\nSELECT\n?orderSizeBucket\n(COUNT(?transaction) AS ?transactionCount)\n(SUM(?totalPrice) AS ?totalRevenue)\n(ROUND(AVG(?totalPrice)) AS ?avgValue)\nWHERE {\n  GRAPH <https://linkeddata.uriburner.com/DAV/demos/daas/databricks-virtuoso-kg-deepseek_v4pro-1.ttl> {\n  \n    ?transaction a :Transaction;\n     :totalPrice ?totalPrice.\n    BIND(\n      IF(?totalPrice < 10, \"Small (<$10)\",\n      IF(?totalPrice < 30, \"Medium ($10-$30)\",\n      IF(?totalPrice < 60, \"Large ($30-$60)\",\n      \"Enterprise (>$60)\")))\n      AS ?orderSizeBucket)\n  \n  }\n}\nGROUP BY ?orderSizeBucket\nORDER BY DESC(?totalRevenue)"
      }
    ]
  },
  {
