  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#step6",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#howtoSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Step 6: Weave in DCAT and PROV-O Metadata"
      }
    ],
    "http://schema.org/position": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 6
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Describe each medallion layer as a DCAT Dataset with distributions and data services. Add PROV-O provenance links connecting Gold-layer entities back to their source systems. The catalog metadata now lives alongside the data in the same RDF graph."
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#knowledgeGraphCatalog",
    "@type": [
      "http://schema.org/DataCatalog"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A data catalog where catalog metadata (DCAT) and instance data coexist in the same RDF knowledge graph, enabling SPARQL queries that span both catalog descriptions and customer facts."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#catalogSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Knowledge Graph-Powered Data Catalog"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#termSemanticEnrichment",
    "@type": [
      "http://schema.org/DefinedTerm",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The progressive addition of meaning to data as it moves through the medallion layers: none at Bronze, local at Silver (IRIs within a domain), global at Gold (cross-domain ontology linking)."
      }
    ],
    "http://schema.org/inDefinedTermSet": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#glossarySection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Semantic Enrichment"
      }
    ],
    "http://schema.org/termCode": [
      {
        "@value": "semantic-enrichment"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQuery3",
    "@type": [
      "http://schema.org/SoftwareSourceCode"
    ],
    "http://schema.org/codeSampleType": [
      {
        "@value": "SELECT query"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Cross-domain SPARQL query that finds all customers who have both a billing issue AND an active contract — a pattern that would be difficult to express in SQL across siloed systems but is natural in a knowledge graph."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQuerySection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "SPARQL Query: Customers with Billing Issues and Active Contracts"
      }
    ],
    "http://schema.org/potentialAction": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQ3LiveAction"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "SPARQL"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#uriburnerEndpoint"
      }
    ],
    "http://schema.org/text": [
      {
        "@value": "PREFIX : <https://moderndata101.substack.com/p/the-semantic-medallion#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\nSELECT ?customer ?name ?issueDescription ?contractStatus WHERE {\n  ?customer a :Customer ;\n    :hasName ?name ;\n    :hasBillingIssue ?issue ;\n    :hasContract ?contract .\n  ?issue a :BillingIssue ;\n    :issueDescription ?issueDescription .\n  ?contract a :Contract ;\n    :contractStatus \"Active\" .\n}\nORDER BY ?name"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#GoldLayer",
    "@type": [
      "http://www.w3.org/2000/01/rdf-schema#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "The Gold layer of the Semantic Medallion where DataFrames are mapped to RDF via a shared ontology (e.g., using OTTR templates and maplib) — global semantics with linked data."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
