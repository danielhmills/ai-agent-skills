  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#q8",
    "@type": [
      "http://schema.org/Question"
    ],
    "http://schema.org/acceptedAnswer": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a8"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "What kinds of queries does the knowledge graph catalog enable?"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "What kinds of queries does the knowledge graph catalog enable?"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a8",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "The knowledge graph catalog enables three categories of queries: (1) entity lookup — retrieve all facts about a single entity; (2) provenance tracing — list all source systems contributing to a record; (3) cross-domain pattern detection — find entities that match conditions spanning multiple domains, such as customers with both active contracts and open billing issues. These cross-domain queries are particularly powerful because they traverse relationships that would require complex joins across siloed SQL databases."
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#q4",
    "@type": [
      "http://schema.org/Question"
    ],
    "http://schema.org/acceptedAnswer": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a4"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "What role do OTTR templates play?"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "What role do OTTR templates play?"
      }
    ]
  },
  {
