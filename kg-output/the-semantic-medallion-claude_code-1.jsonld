  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#semanticMedallionOntology",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Ontology modeling the Semantic Medallion architecture: Bronze (raw harvest), Silver (IRI minting), and Gold (RDF knowledge graph) layers, augmented with DCAT catalog vocabulary, PROV-O provenance, and sample customer-domain entities that make SPARQL query examples executable."
      }
    ],
    "http://schema.org/identifier": [
      {
        "@value": "https://moderndata101.substack.com/p/the-semantic-medallion"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "Semantic Medallion Ontology"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A lightweight ontology for modeling medallion architecture layers augmented with knowledge graphs, DCAT catalog metadata, data lineage provenance, and customer-domain entities as described in 'The Semantic Medallion' article by Veronika Heimsbakk."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
