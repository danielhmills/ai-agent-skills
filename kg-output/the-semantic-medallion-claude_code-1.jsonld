    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The Bronze layer harvests raw data from source systems with no semantic enrichment — it is the raw material ingestion stage of the medallion."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#analysis"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "The Bronze Layer — Raw Data Harvest"
      }
    ]
  },
