  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#dcatSection",
    "@type": [
      "http://schema.org/ArticleSection"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The W3C Data Catalog Vocabulary (DCAT) is applied at each medallion layer to describe datasets, distributions, and data services. Catalog metadata and instance data coexist in the same RDF graph, making the catalog self-describing."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#analysis"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "DCAT in the Architecture"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#q12",
    "@type": [
      "http://schema.org/Question"
    ],
    "http://schema.org/acceptedAnswer": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a12"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "How does the Semantic Medallion compare to a traditional data catalog?"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "How does the Semantic Medallion compare to a traditional data catalog?"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQuery1",
    "@type": [
      "http://schema.org/SoftwareSourceCode"
    ],
    "http://schema.org/codeSampleType": [
      {
        "@value": "SELECT query"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Retrieves all property-value pairs for customer C-001 from the knowledge graph. This is the simplest entry point into the catalog — look up everything known about a single entity."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQuerySection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "SPARQL Query: All Facts About Customer C-001"
      }
    ],
    "http://schema.org/potentialAction": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQ1LiveAction"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "SPARQL"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#uriburnerEndpoint"
      }
    ],
    "http://schema.org/text": [
      {
        "@value": "PREFIX : <https://moderndata101.substack.com/p/the-semantic-medallion#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX prov: <http://www.w3.org/ns/prov#>\n\nSELECT ?property ?value WHERE {\n  :C-001 ?property ?value .\n  OPTIONAL { ?value rdfs:label ?label }\n}\nORDER BY ?property"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#SilverLayer",
