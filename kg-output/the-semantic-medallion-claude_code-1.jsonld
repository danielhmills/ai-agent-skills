    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Step 1: Harvest Raw Data into the Bronze Layer"
      }
    ],
    "http://schema.org/position": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Ingest raw data from all source systems — CRM, ERP, billing, support — into the Bronze layer. Apply no transformations. Preserve original formats and timestamps. This is raw material only."
      }
    ]
  },
