  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#step7",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#howtoSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Step 7: Query and Validate"
      }
    ],
    "http://schema.org/position": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 7
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Load the RDF into a SPARQL-capable triplestore (e.g., Virtuoso). Run validation queries to confirm entity counts and relationship integrity. Apply SHACL shapes for data quality enforcement. Then query your knowledge graph catalog — start with entity lookup, progress to provenance tracing, and finally cross-domain pattern detection."
      }
    ]
  },
  {
