  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#maplib",
    "@type": [
      "http://schema.org/SoftwareApplication"
    ],
    "http://schema.org/applicationCategory": [
      {
        "@value": "Data Transformation Library"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Python library for DataFrame-to-RDF transformation using OTTR templates. Enables a single maplib.map() call to convert Silver-layer DataFrames into RDF triples."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#technologySection"
      }
    ],
    "http://schema.org/name": [
      {
        "@value": "maplib"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "Python"
      }
    ],
    "http://schema.org/url": [
      {
        "@value": "https://github.com/DataTreehouse/maplib"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a2",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "In the Semantic Medallion, the Bronze layer functions identically to traditional medallion — it harvests raw data from source systems without transformation. The difference emerges at Silver, where IRIs are minted instead of just cleaning data."
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a1",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "The Semantic Medallion is an augmentation of the traditional medallion data architecture (Bronze → Silver → Gold) where the Gold layer becomes an RDF knowledge graph instead of clean tabular data. DCAT catalog metadata is woven into the same graph, creating a self-describing knowledge graph-powered data catalog."
      }
    ]
  },
