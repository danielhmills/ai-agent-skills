  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#termOTTR",
    "@type": [
      "http://schema.org/DefinedTerm",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A framework for template-based ontology mapping. stOTTR (string syntax) defines reusable templates that declaratively map structured data columns to RDF ontology classes and properties."
      }
    ],
    "http://schema.org/inDefinedTermSet": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#glossarySection"
