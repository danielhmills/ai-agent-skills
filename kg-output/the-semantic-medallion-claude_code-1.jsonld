  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a12",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Traditional data catalogs describe where data lives (table names, column schemas, storage locations) but do not describe how data connects across systems. A knowledge graph-powered catalog captures both — DCAT metadata describes the datasets while RDF relationships connect customer entities to their source systems, contracts, and issues. The catalog becomes queryable in the same SPARQL endpoint as the data it describes."
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a10",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "SHACL (Shapes Constraint Language) is a W3C standard for validating RDF data against shape conditions. In the Semantic Medallion architecture, SHACL shapes can be applied to the Gold layer to enforce data quality rules — ensuring every Customer has required properties, contracts have valid statuses, and data sources are properly typed."
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#step4",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#howtoSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Step 4: Author OTTR Templates"
      }
    ],
    "http://schema.org/position": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Write stOTTR templates that map Silver-layer DataFrame columns to your shared ontology. Each template defines how a row becomes RDF: which column maps to which class, which columns become properties, and how IRIs are constructed. Templates make the mapping declarative and reusable."
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#bronzeLayer",
    "@type": [
      "https://moderndata101.substack.com/p/the-semantic-medallion#BronzeLayer",
      "http://schema.org/Thing"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Raw data harvested from source systems. No semantics applied — pure raw material ingestion. Data is stored as-is from CRM, ERP, billing, and other operational systems."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#semanticMedallionOntology"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Bronze Layer"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Bronze Layer"
      }
    ],
    "https://moderndata101.substack.com/p/the-semantic-medallion#layerName": [
      {
        "@value": "Bronze"
      }
    ],
    "https://moderndata101.substack.com/p/the-semantic-medallion#layerOrder": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "https://moderndata101.substack.com/p/the-semantic-medallion#semanticEnrichment": [
      {
        "@value": "none"
      }
    ],
    "https://moderndata101.substack.com/p/the-semantic-medallion#transformsTo": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#silverLayer"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#step3",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#howtoSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Step 3: Design a Shared Ontology"
      }
    ],
    "http://schema.org/position": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Define the core classes (e.g., Customer, Contract, DataSource) and properties (e.g., hasContract, wasDerivedFrom) that span your business domains. Start minimal — a small shared ontology that captures cross-domain relationships. Expand iteratively as new use cases emerge. Document every class and property with rdfs:label and rdfs:comment."
      }
    ]
  },
  {
