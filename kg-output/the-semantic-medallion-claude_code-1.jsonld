    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#provO",
    "@type": [
      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "W3C Provenance Ontology for tracking data lineage — where data came from, who generated it, and what transformations were applied."
