      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#goldSection",
    "@type": [
      "http://schema.org/ArticleSection"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The Gold layer transforms DataFrames into RDF using a shared ontology via OTTR templates and maplib, achieving global semantics where entities connect across systems."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#analysis"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "The Gold Layer — RDF Knowledge Graph"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a7",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "PROV-O (Provenance Ontology) tracks data lineage — where each record came from, which system generated it, and what transformations were applied. In the catalog, provenance links connect customer facts back to their source systems, answering questions like 'Which CRM and billing records contributed to this customer view?'"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#iriMinting",
    "@type": [
      "http://schema.org/DefinedTerm"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The process of assigning stable globally unique Internationalized Resource Identifiers to every entity at the Silver layer, ensuring entities can be referenced and linked across systems."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#silverSection"
      }
