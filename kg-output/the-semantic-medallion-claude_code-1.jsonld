      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#knowledgeGraphCatalog"
      }
    ],
    "http://schema.org/abstract": [
      {
        "@language": "en",
        "@value": "Augmenting the traditional medallion architecture by making the Gold layer an RDF knowledge graph instead of clean tabular data, then using DCAT to weave catalog metadata into the same graph."
      }
    ],
    "http://schema.org/articleBody": [
      {
        "@language": "en",
        "@value": "The Semantic Medallion proposes upgrading the traditional Bronze-Silver-Gold data architecture. Bronze harvests raw data. Silver mints stable globally unique IRIs for every entity. Gold maps DataFrames to RDF via a shared ontology using OTTR templates and maplib. The result is a knowledge graph-powered data catalog where DCAT metadata and customer facts coexist in the same queryable graph, enabling entity resolution, semantic search, and impact analysis through SPARQL."
      }
    ],
    "http://schema.org/author": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#veronikaHeimsbakk"
      }
    ],
