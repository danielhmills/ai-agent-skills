    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "OTTR (Reasonable Ontology Templates)"
      }
    ],
    "http://schema.org/termCode": [
      {
        "@value": "ottr"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#termKnowledgeGraph",
    "@type": [
      "http://schema.org/DefinedTerm",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A graph-structured representation of data where entities are nodes connected by typed relationships, enabling semantic querying and inference beyond what relational databases support."
      }
    ],
    "http://schema.org/inDefinedTermSet": [
      {
