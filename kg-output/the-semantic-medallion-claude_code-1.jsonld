        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#MedallionLayer"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#semanticMedallionOntology"
