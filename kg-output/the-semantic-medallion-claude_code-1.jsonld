  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a6",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "DCAT (Data Catalog Vocabulary) is a W3C standard for describing data catalogs, datasets, distributions, and data services in RDF. In the Semantic Medallion, each medallion layer receives DCAT descriptions — the catalog metadata and the actual data coexist in the same graph, making the catalog self-describing rather than a separate metadata store."
      }
    ]
  },
  {
