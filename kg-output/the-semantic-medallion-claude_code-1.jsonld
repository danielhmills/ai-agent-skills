    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A layer in the medallion data architecture representing a stage of semantic enrichment: Bronze (raw data), Silver (IRI-minted entities), or Gold (RDF knowledge graph with global semantics)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#semanticMedallionOntology"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Medallion Layer"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#layerName",
    "@type": [
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "The name of a medallion architecture layer."
      }
    ],
