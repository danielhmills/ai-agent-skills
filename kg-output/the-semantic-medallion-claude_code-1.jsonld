  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQuery2",
    "@type": [
      "http://schema.org/SoftwareSourceCode"
    ],
    "http://schema.org/codeSampleType": [
      {
        "@value": "SELECT query"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Lists all data source systems that contributed records for customer C-001, showing the provenance chain. Uses PROV-O wasDerivedFrom to trace lineage back to source systems."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQuerySection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "SPARQL Query: Contributing Data Sources for Customer C-001"
      }
    ],
    "http://schema.org/potentialAction": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQ2LiveAction"
      }
    ],
    "http://schema.org/programmingLanguage": [
      {
        "@value": "SPARQL"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#uriburnerEndpoint"
      }
    ],
    "http://schema.org/text": [
      {
        "@value": "PREFIX : <https://moderndata101.substack.com/p/the-semantic-medallion#>\nPREFIX prov: <http://www.w3.org/ns/prov#>\n\nSELECT ?source ?sourceName ?sourceType WHERE {\n  :C-001 prov:wasDerivedFrom ?source .\n  ?source a :DataSource ;\n    :sourceName ?sourceName ;\n    :sourceType ?sourceType .\n}\nORDER BY ?sourceName"
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQ2LiveAction",
    "@type": [
      "http://schema.org/SearchAction"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQuerySection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Run Query 2 Live"
      }
    ],
    "http://schema.org/target": [
      {
        "@id": "_:ne97944ba89b94d57af623cc83450d359b2"
      }
    ]
  },
  {
    "@id": "_:ne97944ba89b94d57af623cc83450d359b2",
    "@type": [
      "http://schema.org/EntryPoint"
    ],
    "http://schema.org/httpMethod": [
      {
        "@value": "GET"
      }
    ],
    "http://schema.org/url": [
      {
        "@value": "https://linkeddata.uriburner.com/sparql?default-graph-uri=&query=PREFIX%20%3A%20%3Chttps%3A%2F%2Fmoderndata101.substack.com%2Fp%2Fthe-semantic-medallion%23%3E%0APREFIX%20prov%3A%20%3Chttp%3A%2F%2Fwww.w3.org%2Fns%2Fprov%23%3E%0ASELECT%20%3Fsource%20%3FsourceName%20%3FsourceType%20WHERE%20%7B%0A%20%20GRAPH%20%3Chttps%3A%2F%2Flinkeddata.uriburner.com%2FDAV%2Fdemos%2Fdaas%2Fthe-semantic-medallion-claude_code-1.ttl%3E%20%7B%0A%20%20%20%20%3AC-001%20prov%3AwasDerivedFrom%20%3Fsource%20.%0A%20%20%20%20%3Fsource%20a%20%3ADataSource%20%3B%0A%20%20%20%20%20%20%3AsourceName%20%3FsourceName%20%3B%0A%20%20%20%20%20%20%3AsourceType%20%3FsourceType%20.%0A%20%20%7D%0A%7D%0AORDER%20BY%20%3FsourceName&format=text%2Fhtml&timeout=0&debug=on&run=+Run+Query+"
      }
    ]
  },
