  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a9",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Entity resolution happens naturally through IRI alignment. Because every entity receives a globally unique IRI at the Silver layer, records from different source systems that refer to the same real-world entity are linked to the same IRI. The Gold layer's ontology then connects these IRIs across domains, enabling graph-based deduplication and identity resolution."
      }
    ]
  },
  {
    "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#a5",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://moderndata101.substack.com/p/the-semantic-medallion#faqSection"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "maplib is a Python library that accepts a pandas DataFrame, an OTTR template, and a result RDF container, then executes the mapping in a single call: `maplib.map(dataframe, template, result_container)`. This reduces what would otherwise be hundreds of lines of triple-construction code to four lines of Python."
      }
    ]
  },
