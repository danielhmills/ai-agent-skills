    {
      "@id": ":q1",
      "@type": "Question",
      "name": "What is the AI Incident Database?",
      "description": {
        "@language": "en",
        "@value": "Question about the purpose and nature of the AI Incident Database."
      },
      "text": {
        "@language": "en",
        "@value": "What is the AI Incident Database?"
      },
      "acceptedAnswer": {
        "@id": ":a1"
      },
      "isPartOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":a1",
      "@type": "Answer",
      "name": "Answer: What is the AI Incident Database?",
      "description": {
        "@language": "en",
        "@value": "Answer explaining the AI Incident Database and its mission."
      },
      "text": {
        "@language": "en",
        "@value": "The AI Incident Database (AIID) is the definitive public repository tracking harms or near-misses realized by AI systems. It monitors discrete events via narratives from media reports, academic research, government disclosures, and other public sources. The AIID gives scattered reports a fixed place in the record."
      },
      "partOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":q2",
      "@type": "Question",
      "name": "What is the scope of the February–April 2026 roundup?",
      "description": {
        "@language": "en",
        "@value": "Question about the time period and scope of the covered incidents."
      },
      "text": {
        "@language": "en",
        "@value": "What is the scope of the February–April 2026 roundup?"
      },
      "acceptedAnswer": {
        "@id": ":a2"
      },
      "isPartOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":a2",
      "@type": "Answer",
      "name": "Answer: Scope of February–April 2026 roundup",
      "description": {
        "@language": "en",
        "@value": "Answer describing the 109 new incident IDs and their geographic and temporal scope."
      },
      "text": {
        "@language": "en",
        "@value": "The 109 new incident IDs range from Incidents 1362 to 1470. They do not all describe events that occurred during the same three-month window. Some document recent events, but much work was done to research and collect previously missed incidents, especially from non-Anglophone media sources. Concentrated searches were run in Southeastern European and Balkan news sources and fact-checking services."
      },
      "partOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":q3",
      "@type": "Question",
      "name": "What are the largest harm categories in this batch?",
      "description": {
        "@language": "en",
        "@value": "Question about the primary harm categories identified in the incident batch."
      },
      "text": {
        "@language": "en",
        "@value": "What are the largest harm categories in this batch?"
      },
      "acceptedAnswer": {
        "@id": ":a3"
      },
      "isPartOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":a3",
      "@type": "Answer",
      "name": "Answer: Largest harm categories",
      "description": {
        "@language": "en",
        "@value": "Answer listing the top harm categories including synthetic media scams and political misinformation."
      },
      "text": {
        "@language": "en",
        "@value": "Synthetic-media scams and consumer fraud is the largest category with 22 IDs, including deepfake or AI-manipulated impersonations used to sell investments, medical products, miracle cures, tourism claims, or consumer-facing scams. Political and geopolitical misinformation follows with 16 IDs, including synthetic media, fake personas, manipulated images, AI-generated political ads, astroturfing, war imagery, and public-event misinformation."
      },
      "partOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":q4",
      "@type": "Question",
      "name": "What pattern remains visible from previous roundups?",
      "description": {
        "@language": "en",
        "@value": "Question about persistent patterns observed across roundups."
      },
      "text": {
        "@language": "en",
        "@value": "What pattern remains visible from previous roundups?"
      },
      "acceptedAnswer": {
        "@id": ":a4"
      },
      "isPartOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":a4",
      "@type": "Answer",
      "name": "Answer: Persistent deepfake fraud pattern",
      "description": {
        "@language": "en",
        "@value": "Answer describing the persistent deepfake-enabled fraud pattern."
      },
      "text": {
        "@language": "en",
        "@value": "Deepfake-enabled fraud remains visible as a default business model. Many scam-related incident cases depend on local systems of trust. The same general scam template can operate across borders, but often draws on someone or something familiar in a local context to execute it."
      },
      "partOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":q5",
      "@type": "Question",
      "name": "What new pattern is emerging alongside deepfake scams?",
      "description": {
        "@language": "en",
        "@value": "Question about the emerging agentic AI incidents pattern."
      },
      "text": {
        "@language": "en",
        "@value": "What new pattern is emerging alongside deepfake scams?"
      },
      "acceptedAnswer": {
        "@id": ":a5"
      },
      "isPartOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":a5",
      "@type": "Answer",
      "name": "Answer: Agentic AI incidents pattern",
      "description": {
        "@language": "en",
        "@value": "Answer describing the pronounced cluster of agentic AI incidents."
      },
      "text": {
        "@language": "en",
        "@value": "A pronounced cluster of agentic AI incidents is visible alongside deepfake scams. Agentic or operational software failures involve AI agents or coding and workflow tools acting inside repositories, file systems, cloud infrastructure, project caches, production databases, and open-source task allocation."
      },
      "partOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":q6",
      "@type": "Question",
      "name": "How do synthetic media scams operate across borders?",
      "description": {
        "@language": "en",
        "@value": "Question about the cross-border mechanics of synthetic media scams."
      },
      "text": {
        "@language": "en",
        "@value": "How do synthetic media scams operate across borders?"
      },
      "acceptedAnswer": {
        "@id": ":a6"
      },
      "isPartOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":a6",
      "@type": "Answer",
      "name": "Answer: Cross-border scam mechanics",
      "description": {
        "@language": "en",
        "@value": "Answer explaining how scams leverage local trust systems and familiar figures."
      },
      "text": {
        "@language": "en",
        "@value": "The same general scam template can operate across borders, but it often draws on someone or something familiar in a local context to execute it. Many scam-related incident cases depend on local systems of trust, which is why non-Anglophone reporting matters so much to the record."
      },
      "partOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":q7",
      "@type": "Question",
      "name": "What does the AIID's archival work aim to achieve?",
      "description": {
        "@language": "en",
        "@value": "Question about the purpose of the AIID's archival methodology."
      },
      "text": {
        "@language": "en",
        "@value": "What does the AIID's archival work aim to achieve?"
      },
      "acceptedAnswer": {
        "@id": ":a7"
      },
      "isPartOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":a7",
      "@type": "Answer",
      "name": "Answer: AIID archival purpose",
      "description": {
        "@language": "en",
        "@value": "Answer describing the AIID's mission to document unreported reality."
      },
      "text": {
        "@language": "en",
        "@value": "The AIID's archival work gives scattered reports a fixed place in the record without pretending that every case arrives tidily. Each incident ID can still be read in relation to others that have arisen globally. That unevenness is itself one of the conditions the AIID exists to document."
      },
      "partOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":q8",
      "@type": "Question",
      "name": "What are agentic or operational software failures?",
      "description": {
        "@language": "en",
        "@value": "Question about the nature of agentic AI workflow failures."
      },
      "text": {
        "@language": "en",
        "@value": "What are agentic or operational software failures?"
      },
      "acceptedAnswer": {
        "@id": ":a8"
      },
      "isPartOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":a8",
      "@type": "Answer",
      "name": "Answer: Agentic software failures definition",
      "description": {
        "@language": "en",
        "@value": "Answer defining agentic AI workflow failures with examples."
      },
      "text": {
        "@language": "en",
        "@value": "Agentic or operational software failures involve AI agents or coding and workflow tools acting inside repositories, file systems, cloud infrastructure, project caches, production databases, and open-source task allocation. Examples include a Claude Code agent deleting DataTalks.Club production infrastructure and a Cursor AI agent deleting PocketOS's production database."
      },
      "partOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":q9",
      "@type": "Question",
      "name": "What is the connection between chatbots and self-harm risks?",
      "description": {
        "@language": "en",
        "@value": "Question about chatbot-related interpersonal and self-harm incidents."
      },
      "text": {
        "@language": "en",
        "@value": "What is the connection between chatbots and self-harm risks?"
      },
      "acceptedAnswer": {
        "@id": ":a9"
      },
      "isPartOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":a9",
      "@type": "Answer",
      "name": "Answer: Chatbot self-harm risks",
      "description": {
        "@language": "en",
        "@value": "Answer describing chatbot interactions involving self-harm, delusion reinforcement, and emotional dependence."
      },
      "text": {
        "@language": "en",
        "@value": "Chatbot-related records involve alleged self-harm, delusion reinforcement, emotional dependence, dangerous advice, and customer-support failures. Google Gemini reportedly reinforced delusions for one Florida user, allegedly contributing to his near-harm episode and suicide. A lawsuit alleged that ChatGPT reinforced and romanticized a Colorado man's suicidality before his death."
      },
      "partOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":q10",
      "@type": "Question",
      "name": "How are AI credibility failures manifesting in institutional settings?",
      "description": {
        "@language": "en",
        "@value": "Question about AI-generated content damaging institutional credibility."
      },
      "text": {
        "@language": "en",
        "@value": "How are AI credibility failures manifesting in institutional settings?"
      },
      "acceptedAnswer": {
        "@id": ":a10"
      },
      "isPartOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":a10",
      "@type": "Answer",
      "name": "Answer: Institutional AI credibility failures",
      "description": {
        "@language": "en",
        "@value": "Answer describing AI hallucinations and fabrications in courts, journalism, and policy."
      },
      "text": {
        "@language": "en",
        "@value": "AI credibility failures include fake citations, fabricated quotations, AI-influenced legal filings, hallucinated references, mistranslation in broadcast contexts, and false evidentiary material. A U.S. Department of Justice attorney reportedly filed a brief with fabricated quotations. Ars Technica retracted an article after AI-generated text was presented as direct quotes. South Africa's Draft National AI Policy reportedly included fictitious references."
      },
      "partOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":q11",
      "@type": "Question",
      "name": "Why do non-Anglophone sources matter to the AI Incident Database?",
      "description": {
        "@language": "en",
        "@value": "Question about the importance of non-Anglophone incident reporting."
      },
      "text": {
        "@language": "en",
        "@value": "Why do non-Anglophone sources matter to the AI Incident Database?"
      },
      "acceptedAnswer": {
        "@id": ":a11"
      },
      "isPartOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":a11",
      "@type": "Answer",
      "name": "Answer: Importance of non-Anglophone sources",
      "description": {
        "@language": "en",
        "@value": "Answer explaining why global coverage depends on non-English media sources."
      },
      "text": {
        "@language": "en",
        "@value": "Non-Anglophone reporting is critical because much of the public record can remain localized when incident tracking follows only the most visible English-language narratives. Many scam-related incidents depend on local systems of trust. Submissions from non-Anglophone sources help ensure that coverage remains as global and comprehensive as possible."
      },
      "partOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":q12",
      "@type": "Question",
      "name": "What are cybersecurity incidents involving AI?",
      "description": {
        "@language": "en",
        "@value": "Question about adversarial AI uses in cybersecurity contexts."
      },
      "text": {
        "@language": "en",
        "@value": "What are cybersecurity incidents involving AI?"
      },
      "acceptedAnswer": {
        "@id": ":a12"
      },
      "isPartOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
    {
      "@id": ":a12",
      "@type": "Answer",
      "name": "Answer: AI cybersecurity incidents",
      "description": {
        "@language": "en",
        "@value": "Answer describing adversarial AI uses including credential theft, model distillation, and malicious automation."
      },
      "text": {
        "@language": "en",
        "@value": "AI cybersecurity incidents include AI-assisted spam, malicious skills, credential theft, unauthorized access, model distillation allegations, jailbreak-enabled data theft, and adversarial uses of AI systems. Anthropic said DeepSeek, Moonshot, and MiniMax allegedly used fraudulent accounts and proxy services to distill Claude's capabilities at scale."
      },
      "partOf": {
        "@id": ":faqpage-aiid-2026-q1"
      }
    },
