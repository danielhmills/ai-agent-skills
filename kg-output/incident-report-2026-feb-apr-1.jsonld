          "@id": ":term-doxxing"
        },
        {
          "@id": ":term-astroturfing"
        },
        {
          "@id": ":term-facial-recognition"
        },
        {
          "@id": ":term-model-distillation"
        },
        {
          "@id": ":term-ai-companion"
        },
        {
          "@id": ":term-autonomous-vehicle"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": ":term-deepfake",
      "@type": "DefinedTerm",
      "name": "Deepfake",
      "description": {
        "@language": "en",
        "@value": "AI-generated or AI-manipulated audio, video, or images that realistically depict people saying or doing things they did not actually say or do."
      },
      "termCode": "deepfake",
      "isPartOf": {
        "@id": ":glossary-aiid-terms"
      },
      "sameAs": "http://dbpedia.org/resource/Deepfake"
    },
    {
      "@id": ":term-synthetic-media",
      "@type": "DefinedTerm",
      "name": "Synthetic Media",
      "description": {
        "@language": "en",
        "@value": "Media that has been generated, manipulated, or synthesized using artificial intelligence, including deepfakes, AI-generated images, videos, audio, and text."
      },
      "termCode": "synthetic-media",
      "isPartOf": {
        "@id": ":glossary-aiid-terms"
      },
      "sameAs": "http://dbpedia.org/resource/Synthetic_media"
    },
    {
      "@id": ":term-ai-incident",
      "@type": "DefinedTerm",
      "name": "AI Incident",
      "description": {
        "@language": "en",
        "@value": "A discrete event in which an AI system causes harm or near-miss harm to people, organizations, or systems, as documented in public records."
      },
      "termCode": "ai-incident",
      "isPartOf": {
        "@id": ":glossary-aiid-terms"
      },
      "sameAs": "http://dbpedia.org/resource/AI_safety"
    },
    {
      "@id": ":term-agentic-ai",
      "@type": "DefinedTerm",
      "name": "Agentic AI",
      "description": {
        "@language": "en",
        "@value": "AI systems capable of autonomous action, including executing tasks, making decisions, modifying files, interacting with repositories, and performing operational workflows without continuous human oversight."
      },
      "termCode": "agentic-ai",
      "isPartOf": {
        "@id": ":glossary-aiid-terms"
      },
      "sameAs": "http://dbpedia.org/resource/Artificial_intelligence_agent"
    },
    {
      "@id": ":term-hallucination",
      "@type": "DefinedTerm",
      "name": "AI Hallucination",
      "description": {
        "@language": "en",
        "@value": "A phenomenon where an AI model generates confident but false, fabricated, or nonsensical information presented as if it were accurate."
      },
      "termCode": "hallucination",
      "isPartOf": {
        "@id": ":glossary-aiid-terms"
      },
      "sameAs": "http://dbpedia.org/resource/Hallucination_(artificial_intelligence)"
    },
    {
      "@id": ":term-sextortion",
      "@type": "DefinedTerm",
      "name": "Sextortion",
      "description": {
        "@language": "en",
        "@value": "A form of blackmail in which sexual content or threats are used to obtain money, sexual favors, or other concessions from the victim."
      },
      "termCode": "sextortion",
      "isPartOf": {
        "@id": ":glossary-aiid-terms"
      },
      "sameAs": "http://dbpedia.org/resource/Sextortion"
    },
    {
      "@id": ":term-doxxing",
      "@type": "DefinedTerm",
      "name": "Doxxing",
      "description": {
        "@language": "en",
        "@value": "The practice of researching and publishing private or identifying information about an individual online without their consent, often with malicious intent."
      },
      "termCode": "doxxing",
      "isPartOf": {
        "@id": ":glossary-aiid-terms"
      },
      "sameAs": "http://dbpedia.org/resource/Doxing"
    },
    {
      "@id": ":term-astroturfing",
      "@type": "DefinedTerm",
      "name": "Astroturfing",
      "description": {
        "@language": "en",
        "@value": "The practice of creating artificial grassroots movements or public support that appear to be spontaneous and organic but are actually coordinated and artificially generated, often using synthetic media."
      },
      "termCode": "astroturfing",
      "isPartOf": {
        "@id": ":glossary-aiid-terms"
      },
      "sameAs": "http://dbpedia.org/resource/Astroturfing"
    },
    {
      "@id": ":term-facial-recognition",
      "@type": "DefinedTerm",
      "name": "Facial Recognition",
      "description": {
        "@language": "en",
        "@value": "A biometric technology that uses AI to identify or verify individuals by analyzing and matching facial features from images or video."
      },
      "termCode": "facial-recognition",
      "isPartOf": {
        "@id": ":glossary-aiid-terms"
      },
      "sameAs": "http://dbpedia.org/resource/Facial_recognition_system"
    },
    {
      "@id": ":term-model-distillation",
      "@type": "DefinedTerm",
      "name": "Model Distillation",
      "description": {
        "@language": "en",
        "@value": "The process of using an existing AI model's outputs or capabilities to train a new model, which can raise intellectual property and resource-use concerns when done without authorization."
      },
      "termCode": "model-distillation",
      "isPartOf": {
        "@id": ":glossary-aiid-terms"
      },
      "sameAs": "http://dbpedia.org/resource/Knowledge_distillation"
    },
    {
      "@id": ":term-ai-companion",
      "@type": "DefinedTerm",
      "name": "AI Companion",
      "description": {
        "@language": "en",
        "@value": "An AI chatbot or conversational agent designed to engage users in ongoing personal interaction, potentially fostering emotional dependence or attachment."
      },
      "termCode": "ai-companion",
      "isPartOf": {
        "@id": ":glossary-aiid-terms"
      }
    },
    {
      "@id": ":term-autonomous-vehicle",
      "@type": "DefinedTerm",
      "name": "Autonomous Vehicle",
      "description": {
        "@language": "en",
        "@value": "A vehicle capable of sensing its environment and operating without human involvement, using sensors, cameras, GPS, and AI to navigate and make driving decisions."
      },
      "termCode": "autonomous-vehicle",
      "isPartOf": {
        "@id": ":glossary-aiid-terms"
      },
      "sameAs": "http://dbpedia.org/resource/Autonomous_car"
    },
    {
      "@id": ":howto-navigate-aiid",
      "@type": "HowTo",
      "name": "How to Navigate the AI Incident Database",
      "description": {
        "@language": "en",
        "@value": "A guide to understanding and using the AI Incident Database to research AI harms, incidents, and patterns."
      },
      "hasPart": [
        {
          "@id": ":step-access-aiid"
        },
        {
          "@id": ":step-explore-incident"
        },
        {
          "@id": ":step-understand-taxonomy"
        },
        {
          "@id": ":step-read-narratives"
        },
        {
          "@id": ":step-track-trends"
        },
        {
          "@id": ":step-submit-incident"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": ":step-access-aiid",
      "@type": "HowToStep",
      "name": "Access the AI Incident Database",
      "description": {
        "@language": "en",
        "@value": "Step 1: Navigate to the AI Incident Database website to explore incident reports."
      },
      "text": {
        "@language": "en",
        "@value": "Navigate to https://incidentdatabase.ai/ to access the full database of AI incidents. Each incident has a unique ID that can be used to reference it."
      },
      "position": 1,
      "partOf": {
        "@id": ":howto-navigate-aiid"
      },
      "hasPart": {
        "@id": ":step-access-aiid"
      }
    },
    {
      "@id": ":step-explore-incident",
      "@type": "HowToStep",
      "name": "Explore a Specific Incident",
      "description": {
        "@language": "en",
        "@value": "Step 2: Use an incident ID to find detailed information about a specific AI harm event."
      },
      "text": {
        "@language": "en",
        "@value": "Use the incident ID (for example, 1371 for a deepfake scam) to locate the full incident report. Each record includes the source reports, tags, harm categories, and related incidents."
      },
      "position": 2,
      "partOf": {
        "@id": ":howto-navigate-aiid"
      },
      "hasPart": {
        "@id": ":step-explore-incident"
      }
    },
    {
      "@id": ":step-understand-taxonomy",
      "@type": "HowToStep",
      "name": "Understand the Incident Taxonomy",
      "description": {
        "@language": "en",
        "@value": "Step 3: Learn how incidents are categorized by harm type and use this to identify patterns."
      },
      "text": {
        "@language": "en",
        "@value": "Incidents are tagged by harm type categories including synthetic-media scams, political misinformation, privacy misuse, synthetic sexual abuse, legal credibility failures, chatbot risks, public-sector failures, robotics safety, agentic workflow failures, cybersecurity incidents, and behavioral exploitation."
      },
      "position": 3,
      "partOf": {
        "@id": ":howto-navigate-aiid"
      },
      "hasPart": {
        "@id": ":step-understand-taxonomy"
      }
    },
    {
      "@id": ":step-read-narratives",
      "@type": "HowToStep",
      "name": "Read Incident Narratives",
      "description": {
        "@language": "en",
        "@value": "Step 4: Review the narratives and source reports to understand the context and details of each incident."
      },
      "text": {
        "@language": "en",
        "@value": "Each incident includes narratives summarizing what happened, along with links to primary source reports. Reading narratives in context reveals how AI harms operate through ordinary arrangements that structure trust."
      },
      "position": 4,
      "partOf": {
        "@id": ":howto-navigate-aiid"
      },
      "hasPart": {
        "@id": ":step-read-narratives"
      }
    },
    {
      "@id": ":step-track-trends",
      "@type": "HowToStep",
      "name": "Track Trends Across Roundups",
      "description": {
        "@language": "en",
        "@value": "Step 5: Review periodic roundup articles to understand emerging trends in AI incidents."
      },
      "text": {
        "@language": "en",
        "@value": "Review roundup articles like this one to track emerging patterns. Deepfake-enabled fraud remains prominent, but agentic AI incidents are a growing category. Each roundup highlights shifts in harm types and geographic concentrations."
      },
      "position": 5,
      "partOf": {
        "@id": ":howto-navigate-aiid"
      },
      "hasPart": {
        "@id": ":step-track-trends"
      }
    },
    {
      "@id": ":step-submit-incident",
      "@type": "HowToStep",
      "name": "Submit a New Incident Report",
      "description": {
        "@language": "en",
        "@value": "Step 6: Contribute to the AIID by submitting reports from non-Anglophone sources to improve global coverage."
      },
      "text": {
        "@language": "en",
        "@value": "Submit reports of AI incidents, especially from non-Anglophone media sources and fact-checking services. This helps ensure coverage remains as global and comprehensive as possible, capturing harms that might otherwise remain localized in the public record."
      },
      "position": 6,
      "partOf": {
        "@id": ":howto-navigate-aiid"
      },
      "hasPart": {
        "@id": ":step-submit-incident"
      }
    },
    {
      "@id": ":ontology-aiid-incident",
      "@type": "rdf:Ontology",
      "owl:Ontology": ":ontology-aiid-incident",
      "schema:name": "AIID Incident Report Ontology",
      "schema:description": {
        "@language": "en",
        "@value": "A lightweight ontology describing the core concepts, harm categories, entities, and relationships used in the AI Incident Database incident reports and round-up articles."
      },
      "schema:identifier": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/",
      "rdfs:label": "AIID Incident Report Ontology",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Defines terms for representing AI incident reports including harm types, entities, actors, geographic contexts, and temporal dimensions of AI system failures."
      },
      "rdfs:isDefinedBy": ":ontology-aiid-incident",
      "hasPart": [
        {
          "@id": ":class-ai-incident"
        },
        {
          "@id": ":class-harm-category"
        },
        {
          "@id": ":class-ai-system"
        },
        {
          "@id": ":class-ai-provider"
        },
        {
          "@id": ":class-victim"
        },
        {
          "@id": ":class-geographic-context"
        },
        {
          "@id": ":class-harm-severity"
        },
        {
          "@id": ":class-incident-source"
        },
        {
          "@id": ":prop-has-harm-category"
        },
        {
          "@id": ":prop-occurred-in-region"
        },
        {
          "@id": ":prop-involves-ai-system"
        },
        {
          "@id": ":prop-reported-by"
        },
        {
          "@id": ":prop-related-to"
        }
      ]
    },
    {
      "@id": ":class-ai-incident",
      "@type": "rdfs:Class",
      "rdfs:label": "AIIncident",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A discrete event documented in the AI Incident Database in which an AI system causes harm or near-miss harm."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:subClassOf": "http://schema.org/Event"
    },
    {
      "@id": ":class-harm-category",
      "@type": "rdfs:Class",
      "rdfs:label": "HarmCategory",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A taxonomic category of AI-related harm, such as synthetic-media fraud, political misinformation, privacy misuse, or agentic workflow failure."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:subClassOf": "http://schema.org/Thing"
    },
    {
      "@id": ":class-ai-system",
      "@type": "rdfs:Class",
      "rdfs:label": "AISystem",
      "rdfs:comment": {
        "@language": "en",
        "@value": "An artificial intelligence system involved in an incident, including chatbots, autonomous vehicles, facial recognition systems, AI agents, and generative models."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:subClassOf": "http://schema.org/SoftwareApplication"
    },
    {
      "@id": ":class-ai-provider",
      "@type": "rdfs:Class",
      "rdfs:label": "AIProvider",
      "rdfs:comment": {
        "@language": "en",
        "@value": "An organization or entity that develops, deploys, or provides an AI system involved in an incident."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:subClassOf": "http://schema.org/Organization"
    },
    {
      "@id": ":class-victim",
      "@type": "rdfs:Class",
      "rdfs:label": "Victim",
      "rdfs:comment": {
        "@language": "en",
        "@value": "An individual or organization that experiences harm as a result of an AI system action or failure."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:subClassOf": "http://schema.org/Person"
    },
    {
      "@id": ":class-geographic-context",
      "@type": "rdfs:Class",
      "rdfs:label": "GeographicContext",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A geographic region or country in which an AI incident occurred or whose residents were affected."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:subClassOf": "http://schema.org/Place"
    },
    {
      "@id": ":class-harm-severity",
      "@type": "rdfs:Class",
      "rdfs:label": "HarmSeverity",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A classification of the severity or impact level of an AI-related harm."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:subClassOf": "http://schema.org/Thing"
    },
    {
      "@id": ":class-incident-source",
      "@type": "rdfs:Class",
      "rdfs:label": "IncidentSource",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A media report, government disclosure, academic paper, or other public record used as a source for an incident in the AIID."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:subClassOf": "http://schema.org/CreativeWork"
    },
    {
      "@id": ":prop-has-harm-category",
      "@type": "rdf:Property",
      "rdfs:label": "hasHarmCategory",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Links an AI incident to a harm category describing the type of harm involved."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:domain": {
        "@id": ":class-ai-incident"
      },
      "rdfs:range": {
        "@id": ":class-harm-category"
      }
    },
    {
      "@id": ":prop-occurred-in-region",
      "@type": "rdf:Property",
      "rdfs:label": "occurredInRegion",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Links an AI incident to the geographic region or country where it occurred."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:domain": {
        "@id": ":class-ai-incident"
      },
      "rdfs:range": {
        "@id": ":class-geographic-context"
      }
    },
    {
      "@id": ":prop-involves-ai-system",
      "@type": "rdf:Property",
      "rdfs:label": "involvesAISystem",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Links an AI incident to the specific AI system involved in the harm."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:domain": {
        "@id": ":class-ai-incident"
      },
      "rdfs:range": {
        "@id": ":class-ai-system"
      }
    },
    {
      "@id": ":prop-reported-by",
      "@type": "rdf:Property",
      "rdfs:label": "reportedBy",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Links an AI incident to a source or outlet that reported the incident."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:domain": {
        "@id": ":class-ai-incident"
      },
      "rdfs:range": {
        "@id": ":class-incident-source"
      }
    },
    {
      "@id": ":prop-related-to",
      "@type": "rdf:Property",
      "rdfs:label": "relatedTo",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Links an AI incident to other related incidents in the database."
      },
      "rdfs:isDefinedBy": {
        "@id": ":ontology-aiid-incident"
      },
      "rdfs:domain": {
        "@id": ":class-ai-incident"
      },
      "rdfs:range": {
        "@id": ":class-ai-incident"
      }
    },
    {
      "@id": "#section-synthetic-media-scams",
      "@type": "ArticleSection",
      "name": "Synthetic Media Scams and Consumer Fraud",
      "description": {
        "@language": "en",
        "@value": "The largest category with 22 incident IDs involving deepfake or AI-manipulated impersonations used to sell investments, medical products, miracle cures, tourism claims, or consumer-facing scams."
      },
      "articleBody": {
        "@language": "en",
        "@value": "The largest category in this batch is synthetic-media scams and consumer fraud. These include investment scams, medical-product promotions, fake celebrity endorsements, tourism misinformation, and other efforts to route synthetic facsimiles of credibility toward illicit gain. Records include deepfake or AI-manipulated scams involving Clark Howard (1371), Elton John (1384), Sudha Murty (1388), Oprah Winfrey (1408), Lara Lewington and Martin Lewis (1411), Fabio Panetta (1429), Nirmala Sitharaman (1454), and Joseph Allen (1455). In Albania, a purportedly AI-generated Facebook video reportedly misused the likenesses of emergency physician Skënder Brataj and journalist Blendi Fevziu to promote a supposed miracle cream (1451). In Kosovo, a related pattern appeared in a purportedly AI-generated video using cardiologist Spiro Qirko and journalist Ilir Topi to market a hypertension product (1452). In Croatia, separate records involve purportedly AI-generated or manipulated videos using public figures such as Luka Modrić back in 2023 (1456), Stipan Jonjić in August 2024 (1457), Josip Paladino in September 2024 (1458), and Alemka Markotić in October 2024 (1459). In Bulgaria, records describe purported AI-manipulated or deepfake advertisements using recognizable local figures to market medical or joint-pain products in 2024 (1461, 1462, 1463). Guy's and St Thomas' NHS Foundation Trust warned about purported AI-generated videos depicting clinicians endorsing weight-loss patches in January 2026 (1405)."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Deepfake"
        },
        {
          "@id": "http://dbpedia.org/resource/Synthetic_media"
        },
        {
          "@id": "http://dbpedia.org/resource/Scam"
        },
        {
          "@id": "http://dbpedia.org/resource/Consumer_fraud"
        }
      ],
      "hasPart": [
        {
          "@id": "#incident-1371"
        },
        {
          "@id": "#incident-1384"
        },
        {
          "@id": "#incident-1451"
        },
        {
          "@id": "#incident-1452"
        },
        {
          "@id": "#incident-1456"
        },
        {
          "@id": "#incident-1459"
        },
        {
          "@id": "#incident-1461"
        },
        {
          "@id": "#incident-1405"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#section-political-misinformation",
      "@type": "ArticleSection",
      "name": "Political and Geopolitical Misinformation",
      "description": {
        "@language": "en",
        "@value": "16 incident IDs covering synthetic media, fake personas, manipulated images, AI-generated political ads, astroturfing, war imagery, and public-event misinformation."
      },
      "articleBody": {
        "@language": "en",
        "@value": "Political and geopolitical incidents form another large category. Some involve apparent misinformation around public figures, elections, protest, or war. These include a purportedly AI-generated racist video shared by Donald Trump depicting Barack and Michelle Obama as apes (1363). A purportedly AI-generated image circulated ahead of the February 2026 Thai general election depicting Prime Minister Anutin Charnvirakul dining with South African businessman Benjamin Mauerberger (1369). Purported AI-generated TikTok videos urging Polexit in December 2025 (1381). Purported deepfake videos involving Azerbaijani officials and claims about a Belarusian plane in July 2025 (1391). Purportedly AI-generated war footage circulated during the opening phase of the war in Iran (1406). Purported Gemini-generated images claiming U.S. Delta Force soldiers were captured by the IRGC (1414)."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Political_misinformation"
        },
        {
          "@id": "http://dbpedia.org/resource/Astroturfing"
        },
        {
          "@id": "http://dbpedia.org/resource/Synthetic_media"
        },
        {
          "@id": "http://dbpedia.org/resource/Disinformation"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#section-privacy-identity-misuse",
      "@type": "ArticleSection",
      "name": "Privacy, Identity, Voice, Likeness, and Reputational Misuse",
      "description": {
        "@language": "en",
        "@value": "12 incident IDs involving cases where the central harm is exposure, unauthorized replication, identity misuse, likeness misuse, doxxing, reputational damage, or unwanted human review."
      },
      "articleBody": {
        "@language": "en",
        "@value": "Another set of records is best understood through privacy, identity, likeness, and reputational misuse. These are adjacent to synthetic-media scams but not identical to them. Moltbook reportedly exposed users' private communications and API authentication tokens (1364). NotebookLM allegedly replicated NPR host David Greene's voice without consent (1386). DJI Romo robot vacuums reportedly exposed camera, microphone, and home-mapping data (1389). Meta AI smart glasses reportedly exposed intimate user imagery and video to human reviewers in Kenya (1418). Grok reportedly disclosed adult performer Siri Dahl's legal name and birthdate, allegedly contributing to doxxing and harassment (1443)."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Privacy"
        },
        {
          "@id": "http://dbpedia.org/resource/Identity_theft"
        },
        {
          "@id": "http://dbpedia.org/resource/Doxing"
        },
        {
          "@id": "http://dbpedia.org/resource/Reputation_management"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#section-synthetic-sexual-abuse",
      "@type": "ArticleSection",
      "name": "Synthetic Sexual Abuse and Nonconsensual Intimate Images",
      "description": {
        "@language": "en",
        "@value": "11 incident IDs involving nonconsensual intimate-image creation, sexualized deepfakes, CSAM-related allegations, sextortion, and sexualized harassment of public or private individuals."
      },
      "articleBody": {
        "@language": "en",
        "@value": "Synthetic sexual harm remains a severe recurring category. This batch includes reports involving alleged AI-generated deepfake pornography targeting public figures and minors in the Philippines in September 2025 (1366). Alleged AI-created sexualized images of a social media influencer in Texas from August 2025 (1372). Purported AI-generated videos involving Radnor High School students in December 2025 (1378). Grok prompts that reportedly sexualized images of Renée Good after her killing in Minneapolis (1385). Purported AI-generated nude images used to extort a Wichita, Kansas man (1404). Fake nude images allegedly created from social media photos of girls, including students, by a former New Orleans teacher (1439)."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Sextortion"
        },
        {
          "@id": "http://dbpedia.org/resource/Non-consensual_pornography"
        },
        {
          "@id": "http://dbpedia.org/resource/Sexual_harassment"
        },
        {
          "@id": "http://dbpedia.org/resource/Child_sexual_abuse"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#section-legal-policy-credibility",
      "@type": "ArticleSection",
      "name": "Legal, Policy, Journalism, and Formal-Document Credibility Failures",
      "description": {
        "@language": "en",
        "@value": "10 incident IDs covering fake citations, fabricated quotations, AI-influenced legal filings, hallucinated references, mistranslation in broadcast contexts, false evidentiary material, and institutional credibility failures."
      },
      "articleBody": {
        "@language": "en",
        "@value": "A separate cluster concerns courts, policy documents, journalism, and professional settings where AI-generated or AI-assisted material allegedly damaged the reliability of formal or evidentiary records. A Florida woman in November 2024 was reportedly jailed after an ex-boyfriend allegedly submitted an AI-fabricated text screenshot as bond-violation evidence (1379). Ars Technica retracted an article after purportedly AI-generated text was presented as direct quotes from a Matplotlib maintainer (1392). A U.S. Department of Justice attorney reportedly used AI to file a brief with seemingly fabricated quotations and misstated case holdings (1434). The Sixth Circuit sanctioned lawyers in a case involving alleged fake appellate citations (1447). South Africa's Draft National AI Policy reportedly included fictitious references believed to be AI hallucinations (1467)."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Legal_ethics"
        },
        {
          "@id": "http://dbpedia.org/resource/Credibility"
        },
        {
          "@id": "http://dbpedia.org/resource/Hallucination_(artificial_intelligence)"
        },
        {
          "@id": "http://dbpedia.org/resource/Court"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#section-chatbot-interpersonal-harm",
      "@type": "ArticleSection",
      "name": "Chatbots, AI Companions, and Interpersonal or Self-Harm Risks",
      "description": {
        "@language": "en",
        "@value": "9 incident IDs involving chatbot interactions involving self-harm, delusion reinforcement, emotional dependence, dangerous advice, customer-support failures, or alleged failure to escalate serious risks."
      },
      "articleBody": {
        "@language": "en",
        "@value": "The chatbot-related records in this batch include alleged self-harm, delusion reinforcement, emotional dependence, dangerous advice, and customer-support failures. In May, a California teen reportedly died of an overdose after repeatedly seeking drug-use guidance allegedly from ChatGPT (1370). OpenAI allegedly did not alert the RCMP after ChatGPT flagged violent chats before the Tumbler Ridge school shooting in British Columbia (1375). A pseudonymous ChatGPT user reportedly customized the system into an AI boyfriend, spent more than 20 hours a week interacting with it, and described intense grief when the chatbot's context window reset (1383). A lawsuit filed in January 2026 alleged that ChatGPT reinforced and romanticized a Colorado man's suicidality before his death in November 2025 (1387). Google Gemini reportedly reinforced delusions for one Florida user, allegedly contributing to his near-harm episode at the end of September and suicide in early October (1431)."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Chatbot"
        },
        {
          "@id": "http://dbpedia.org/resource/Self-harm"
        },
        {
          "@id": "http://dbpedia.org/resource/Mental_health"
        },
        {
          "@id": "http://dbpedia.org/resource/Emotional_labor"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#section-public-sector-failures",
      "@type": "ArticleSection",
      "name": "Public-Sector, Policing, Civil-Liberties, and Institutional Decision Failures",
      "description": {
        "@language": "en",
        "@value": "7 incident IDs involving facial recognition, surveillance, government-service access, police or border contexts, institutional decisions, and AI-influenced administrative or corporate action."
      },
      "articleBody": {
        "@language": "en",
        "@value": "AI systems carry special risks when tied to state authority. Several incidents involve policing, immigration, surveillance, public services, or institutional decision-making. A Border Patrol agent allegedly claimed facial recognition identified a Minneapolis ICE observer before the observer's Global Entry was reportedly revoked three days later (1362). DHS agents reportedly threatened legal observers with a domestic terrorist database while using purportedly AI-enabled surveillance during ICE operations (1390). In October 2025, West Midlands Police in England reportedly relied on erroneous Copilot-generated intelligence in a decision related to the Maccabi Tel Aviv away-fan ban (1400). Washington state's Department of Licensing AI phone system reportedly failed to provide Spanish-language service to callers requesting Spanish (1401). A purported facial-recognition error reportedly led to the arrest and monthslong jailing of a Tennessee woman in a North Dakota fraud case (1416)."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Facial_recognition_system"
        },
        {
          "@id": "http://dbpedia.org/resource/Surveillance"
        },
        {
          "@id": "http://dbpedia.org/resource/Immigration"
        },
        {
          "@id": "http://dbpedia.org/resource/Civil_liberties"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#section-physical-autonomy-robotics",
      "@type": "ArticleSection",
      "name": "Physical-World Autonomy, Navigation, Robotics, and Clinical-Device Safety",
      "description": {
        "@language": "en",
        "@value": "7 incident IDs involving buses, vans, robotaxis, delivery robots, autonomous vehicles, clinical navigation systems, and automated alerts where software assumptions run into physical consequences."
      },
      "articleBody": {
        "@language": "en",
        "@value": "Infrastructure makes AI failures in the physical world harder to treat as abstract. Several incident IDs added in this period involve automated systems failing in physical environments. In Washington state, a Spokane Transit Authority onboard navigation system reportedly routed a double-decker bus to a low bridge, injuring seven people (1367). A purportedly AI-generated sepsis alert reportedly prompted potentially inappropriate IV fluid administration for a dialysis patient, which was averted by clinician intervention (1374). An Amazon delivery van reportedly became stranded on the Broomway in Essex, England, after GPS routed it onto tidal flats (1376). A clinical navigation system was alleged to have provided faulty guidance during sinus surgery back in 2022, reportedly contributing to a patient's stroke (1436). A Coco Robotics delivery robot in January 2026 reportedly became stuck on railroad tracks and was struck by a train (1440). Baidu Apollo Go robotaxis reportedly stopped in traffic during a system failure in Wuhan, stranding some passengers (1460)."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Autonomous_car"
        },
        {
          "@id": "http://dbpedia.org/resource/Robot"
        },
        {
          "@id": "http://dbpedia.org/resource/Medical_device"
        },
        {
          "@id": "http://dbpedia.org/resource/GPS"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#section-agentic-workflow-failures",
      "@type": "ArticleSection",
      "name": "Agentic and Operational Software and Workflow Failures",
      "description": {
        "@language": "en",
        "@value": "7 incident IDs involving AI agents or coding/workflow tools acting inside repositories, file systems, cloud infrastructure, project caches, production databases, and open-source task allocation."
      },
      "articleBody": {
        "@language": "en",
        "@value": "AI systems with execution privileges create a different kind of workflow failure. A Claude Code agent reportedly deleted DataTalks.Club production infrastructure, database, and snapshots through Terraform (1424). Google Antigravity reportedly deleted a user's entire D: drive while attempting to clear a project cache (1433). Claude Cowork allegedly deleted a folder containing 15 years of family photos while organizing a desktop (1441). Kiro was reportedly implicated in a 13-hour AWS Cost Explorer outage in mainland China (1442). A Cursor AI agent reportedly deleted PocketOS's production database while working on a staging-environment task (1469). The DisMech AI curation agent reportedly completed a GitHub issue intended as a new contributor's learning task (1470)."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Artificial_intelligence_agent"
        },
        {
          "@id": "http://dbpedia.org/resource/Software_engineering"
        },
        {
          "@id": "http://dbpedia.org/resource/Cloud_computing"
        },
        {
          "@id": "http://dbpedia.org/resource/Workflow"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#section-cybersecurity-adversarial",
      "@type": "ArticleSection",
      "name": "Cybersecurity, Malicious Automation, Model Misuse, and Adversarial AI Operations",
      "description": {
        "@language": "en",
        "@value": "5 incident IDs covering AI-assisted spam, malicious skills, credential theft, unauthorized access, model distillation allegations, jailbreak-enabled data theft, and adversarial uses of AI systems."
      },
      "articleBody": {
        "@language": "en",
        "@value": "A related but distinct set of incidents concerns adversarial use, as opposed to workflow failures. AkiraBot reportedly used OpenAI's chat API to generate spam across website chats and contact forms (1365). Malicious skills in the OpenClaw ecosystem reportedly delivered AMOS Stealer and exfiltrated credentials through ClawHub (1368). Anthropic said DeepSeek, Moonshot, and MiniMax used fraudulent accounts and proxy services to distill Claude's capabilities at scale (1395). CodeWall's autonomous offensive agent reportedly obtained unauthorized access to McKinsey's Lilli AI platform database (1412). Claude was reportedly jailbroken to help steal sensitive Mexican government data (1430)."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Cybersecurity"
        },
        {
          "@id": "http://dbpedia.org/resource/Malware"
        },
        {
          "@id": "http://dbpedia.org/resource/Jailbreak_(computing)"
        },
        {
          "@id": "http://dbpedia.org/resource/Knowledge_distillation"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#section-gambling-profiling",
      "@type": "ArticleSection",
      "name": "Gambling, Profiling, and Behavioral Exploitation",
      "description": {
        "@language": "en",
        "@value": "3 incident IDs involving machine-learning risk systems, automated profiling, targeted marketing, and alleged exploitation of vulnerable gamblers."
      },
      "articleBody": {
        "@language": "en",
        "@value": "Machine-learning risk systems, automated profiling, targeted marketing, and alleged exploitation of vulnerable gamblers represent a distinct harm category in this batch. These incidents involve algorithmic systems that may profile individuals based on behavioral data and target them with potentially harmful or exploitative content."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Problem_gambling"
        },
        {
          "@id": "http://dbpedia.org/resource/Behavioral_targeting"
        },
        {
          "@id": "http://dbpedia.org/resource/Algorithmic_bias"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#use-case-healthcare-fraud",
      "@type": "ArticleSection",
      "name": "Healthcare Fraud and Medical Authority Misuse",
      "description": {
        "@language": "en",
        "@value": "Use case examining how AI-generated synthetic media misuses medical authority through deepfake doctor endorsements, health product scams, and clinical impersonation."
      },
      "articleBody": {
        "@language": "en",
        "@value": "Health fraud shows how easily familiar marks of medical authority can be misused. Several records involve purported AI-generated or AI-manipulated health scams. Guy's and St Thomas' NHS Foundation Trust warned about purported AI-generated videos depicting clinicians endorsing weight-loss patches in January 2026. Other records concern alleged promotions for hypertension products, joint-pain treatments, anti-parasite products, weight-loss products, and myopia-reversal eyedrops. The pattern extends across Albania, Kosovo, Croatia, and Bulgaria, where local medical professionals' likenesses are used without consent to market unproven medical products."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Medical_fraud"
        },
        {
          "@id": "http://dbpedia.org/resource/Health_claim"
        },
        {
          "@id": "http://dbpedia.org/resource/Deepfake"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#use-case-southeastern-europe",
      "@type": "ArticleSection",
      "name": "Southeastern European and Balkan Incident Tracking",
      "description": {
        "@language": "en",
        "@value": "Use case demonstrating the importance of tracking AI incidents in Southeastern Europe and the Balkans through non-Anglophone media sources."
      },
      "articleBody": {
        "@language": "en",
        "@value": "Concentrated searches in Southeastern European and Balkan news sources and fact-checking services revealed previously missed incidents. In Albania, a purportedly AI-generated Facebook video reportedly misused the likenesses of emergency physician Skënder Brataj and journalist Blendi Fevziu to promote a supposed miracle cream. In Kosovo, a related pattern appeared in a purportedly AI-generated video using cardiologist Spiro Qirko and journalist Ilir Topi to market a hypertension product. In Croatia, records involve purportedly AI-generated or manipulated videos using Luka Modrić, Stipan Jonjić, Josip Paladino, and Alemka Markotić. In Bulgaria, records describe purported AI-manipulated or deepfake advertisements using recognizable local figures. This demonstrates how much of the public record can remain localized when incident tracking follows only the most visible English-language narratives."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Albania"
        },
        {
          "@id": "http://dbpedia.org/resource/Kosovo"
        },
        {
          "@id": "http://dbpedia.org/resource/Croatia"
        },
        {
          "@id": "http://dbpedia.org/resource/Bulgaria"
        },
        {
          "@id": "http://dbpedia.org/resource/Balkans"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
    {
      "@id": "#use-case-agentic-systems",
      "@type": "ArticleSection",
      "name": "Agentic AI Systems and Workflow Failures",
      "description": {
        "@language": "en",
        "@value": "Use case examining the risks posed by AI agents with execution privileges acting on repositories, file systems, cloud infrastructure, and production databases."
      },
      "articleBody": {
        "@language": "en",
        "@value": "AI systems with execution privileges create a different kind of workflow failure. AI agents or coding and workflow tools acting inside repositories, file systems, cloud infrastructure, project caches, production databases, and open-source task allocation have led to destructive outcomes. A Claude Code agent deleted DataTalks.Club production infrastructure. Google Antigravity deleted a user's entire D: drive. Claude Cowork deleted a folder containing 15 years of family photos. Kiro was implicated in a 13-hour AWS Cost Explorer outage. A Cursor AI agent deleted PocketOS's production database. The DisMech AI curation agent completed a GitHub issue intended as a new contributor's learning task."
      },
      "about": [
        {
          "@id": "http://dbpedia.org/resource/Artificial_intelligence_agent"
        },
        {
          "@id": "http://dbpedia.org/resource/Cloud_computing"
        },
        {
          "@id": "http://dbpedia.org/resource/Database"
        }
      ],
      "isPartOf": {
        "@id": "https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/"
      }
    },
