    {
      "@id": ":entity-google",
      "@type": "Organization",
      "name": "Google",
      "description": {
        "@language": "en",
        "@value": "Technology company whose AI systems including Gemini and Copilot are involved in incidents documented in this round-up, including delusion reinforcement, erroneous intelligence generation, and AI-enabled surveillance."
      },
      "url": "https://www.google.com/",
      "sameAs": "http://dbpedia.org/resource/Google"
