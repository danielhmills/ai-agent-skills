<> a schema:TechArticle ;
    schema:name "RDF 1.2 Primer" ;
    schema:description "A W3C Group Note Draft providing the basic knowledge required to effectively use RDF. It introduces the basic concepts of RDF and shows concrete examples of the use of RDF." ;
    schema:about <http://dbpedia.org/resource/Resource_Description_Framework> ,
                 <http://dbpedia.org/resource/Triple_(information_technology)> ,
                 <http://dbpedia.org/resource/Internationalized_Resource_Identifier> ;
    schema:author :champin , :lindstrom , :schreiber , :raimond , :manola , :emiller , :mcbride ;
    schema:publisher <https://www.w3.org/> ;
    schema:datePublished "2026-04-16"^^xsd:date ;
    schema:dateModified "2026-04-16"^^xsd:date ;
    schema:version "W3C Group Note Draft" ;
    schema:url <https://www.w3.org/TR/rdf12-primer/> ;
    schema:keywords "RDF", "Resource Description Framework", "Linked Data", "Semantic Web", "RDF 1.2" ;
    schema:articleBody "This primer provides the basic knowledge required to effectively use RDF. It introduces the basic concepts of RDF and shows concrete examples. RDF is a framework for expressing information about resources, which can be documents, people, physical objects, and abstract concepts. RDF provides a common framework for exchanging information between applications without loss of meaning. Secs. 3-5 provide a minimalist introduction to key RDF elements including triples, IRIs, literals, blank nodes, and triple terms. The document also covers RDF vocabularies, writing RDF graphs in various syntaxes (Turtle, JSON-LD, RDFa, RDF/XML), and the semantics of RDF graphs." ;
    schema:isPartOf <https://www.w3.org/TR/> ;
    schema:hasPart :faqSection , :glossarySection , :howtoSection , :section-Introduction , :section-use-cases , :section-data-model , :section-vocabulary , :section-graph-syntax , :section-semantics , :section-data , :section-conclusion ;
    schema:relatedLink <https://www.w3.org/TR/rdf12-concepts/> ,
                       <https://www.w3.org/TR/rdf12-turtle/> ,
                       <https://www.w3.org/TR/rdf12-schema/> ,
                       <https://www.w3.org/TR/rdf12-semantics/> ,
                       <https://www.w3.org/TR/sparql12-query/> ,
                       <https://www.w3.org/TR/rdf12-xml/> ,
                       <https://w3c.github.io/rdf-new/spec/> ,
                       <https://w3c.github.io/rdf-primer/spec/> ;
    owl:sameAs <http://dbpedia.org/resource/Resource_Description_Framework> ,
               <http://www.wikidata.org/entity/Q8762> ;
    prov:wasGeneratedBy :kg-generator-skill .

