:faqSection a schema:FAQPage ;
    schema:name "RDF 1.2 Primer Frequently Asked Questions" ;
    schema:description "Frequently asked questions about RDF 1.2 concepts, data model, and usage." ;
    schema:mainEntity :q1 , :q2 , :q3 , :q4 , :q5 , :q6 , :q7 , :q8 , :q9 , :q10 , :q11 , :q12 ;
    schema:hasPart :q1 , :q2 , :q3 , :q4 , :q5 , :q6 , :q7 , :q8 , :q9 , :q10 , :q11 , :q12 ;
    schema:isPartOf <> .

:q1 a schema:Question ;
    schema:name "What is RDF?" ;
    schema:text "What is RDF and what is its purpose in the Semantic Web?" ;
    schema:acceptedAnswer :a1 ;
    schema:about <http://dbpedia.org/resource/Resource_Description_Framework> ;
    schema:isPartOf :faqSection ;
    schema:hasPart :a1 .

:a1 a schema:Answer ;
    schema:name "What is RDF? - Answer" ;
    schema:text "The Resource Description Framework (RDF) is a framework for expressing information about resources. Resources can be anything, including documents, people, physical objects, and abstract concepts. RDF is intended for situations in which information on the Web needs to be processed by applications, rather than being only displayed to people. RDF provides a common framework for expressing this information so it can be exchanged between applications without loss of meaning." ;
    schema:isPartOf :faqSection .

:q2 a schema:Question ;
    schema:name "What is an RDF triple?" ;
    schema:text "What are the three components of an RDF triple?" ;
    schema:acceptedAnswer :a2 ;
    schema:about <http://dbpedia.org/resource/Triple_(information_technology)> ;
    schema:isPartOf :faqSection ;
    schema:hasPart :a2 .

:a2 a schema:Answer ;
    schema:name "What is an RDF triple? - Answer" ;
    schema:text "An RDF statement always has the following structure: subject, predicate, object. The subject and object represent the two resources being related; the predicate represents the nature of their relationship. The relationship is phrased in a directional way from subject to object and is called a property. Because RDF statements consist of three elements they are called triples." ;
    schema:isPartOf :faqSection .

:q3 a schema:Question ;
    schema:name "What is an IRI?" ;
    schema:text "What is an IRI in RDF and how does it differ from a URI?" ;
    schema:acceptedAnswer :a3 ;
    schema:about <http://dbpedia.org/resource/Internationalized_Resource_Identifier> ;
    schema:isPartOf :faqSection ;
    schema:hasPart :a3 .

:a3 a schema:Answer ;
    schema:name "What is an IRI? - Answer" ;
    schema:text "IRI stands for Internationalized Resource Identifier. It identifies a resource and is a generalization of URI (Uniform Resource Identifier), allowing non-ASCII characters to be used in the IRI character string. IRIs can appear in all three positions of a triple (subject, predicate, object). The URLs that people use as Web addresses are one form of IRI." ;
    schema:isPartOf :faqSection .

:q4 a schema:Question ;
    schema:name "What are literals in RDF?" ;
    schema:text "How are literal values represented in RDF?" ;
    schema:acceptedAnswer :a4 ;
    schema:isPartOf :faqSection ;
    schema:hasPart :a4 .

:a4 a schema:Answer ;
    schema:name "What are literals in RDF? - Answer" ;
    schema:text "Literals are used to encode values rather than identifying them by IRIs. Examples include strings such as 'La Joconde', dates formatted according to ISO-8601 such as 1990-07-04, and numbers such as 3.14159. Literals are always associated with a datatype. Strings can optionally have a language tag and an initial base direction (ltr or rtl). Literals may only appear in the object position of a triple." ;
    schema:isPartOf :faqSection .

:q5 a schema:Question ;
    schema:name "What are blank nodes in RDF?" ;
    schema:text "What is the purpose of blank nodes in RDF graphs?" ;
    schema:acceptedAnswer :a5 ;
    schema:isPartOf :faqSection ;
    schema:hasPart :a5 .

:a5 a schema:Answer ;
    schema:name "What are blank nodes in RDF? - Answer" ;
    schema:text "Blank nodes represent resources without a global identifier. They are like variables in algebra and can appear in the subject and object position of a triple. Blank nodes are useful when you want to talk about something without explicitly naming it with an IRI. They are represented by identifiers like _:x in Turtle syntax." ;
    schema:isPartOf :faqSection .

:q6 a schema:Question ;
    schema:name "What is an RDF graph?" ;
    schema:text "How is an RDF graph structured?" ;
    schema:acceptedAnswer :a6 ;
    schema:isPartOf :faqSection ;
    schema:hasPart :a6 .

:a6 a schema:Answer ;
    schema:name "What is an RDF graph? - Answer" ;
    schema:text "A set of triples is called a graph. We can visualize a set of triples as a connected graph consisting of nodes and arcs. The subjects and objects of the triples make up the nodes in the graph; the predicates form the arcs. This ability to have the same resource in both subject and object positions makes it possible to find connections between triples." ;
    schema:isPartOf :faqSection .

:q7 a schema:Question ;
    schema:name "What are triple terms in RDF 1.2?" ;
    schema:text "What new feature do triple terms provide in RDF 1.2?" ;
    schema:acceptedAnswer :a7 ;
    schema:isPartOf :faqSection ;
    schema:hasPart :a7 .

:a7 a schema:Answer ;
    schema:name "What are triple terms in RDF 1.2? - Answer" ;
    schema:text "Triple terms (reifying triples) allow describing more detailed circumstances underlying relationships. They enable annotation of statements with additional properties like type and date of origin. The object of a reifying triple is a triple term, which denotes the proposition itself as a logical, abstract object identified through its constituent subject, predicate, and object components. Triple terms may only appear in the object position." ;
    schema:isPartOf :faqSection .

:q8 a schema:Question ;
    schema:name "What is RDF Schema?" ;
    schema:text "How does RDF Schema extend the basic RDF data model?" ;
    schema:acceptedAnswer :a8 ;
    schema:isPartOf :faqSection ;
    schema:hasPart :a8 .

:a8 a schema:Answer ;
    schema:name "What is RDF Schema? - Answer" ;
    schema:text "RDF Schema (RDFS) provides a data-modeling vocabulary for RDF data. It allows defining classes, properties, domain and range restrictions, and hierarchies using constructs like rdf:type, rdfs:Class, rdfs:subClassOf, rdfs:subPropertyOf, rdfs:domain, and rdfs:range. RDFS enables modeling the semantic characteristics of RDF data." ;
    schema:isPartOf :faqSection .

:q9 a schema:Question ;
    schema:name "What is Turtle syntax?" ;
    schema:text "How does Turtle syntax represent RDF triples?" ;
    schema:acceptedAnswer :a9 ;
    schema:isPartOf :faqSection ;
    schema:hasPart :a9 .

:a9 a schema:Answer ;
    schema:name "What is Turtle syntax? - Answer" ;
    schema:text "Turtle (Terse RDF Triple Language) is a human-readable syntax for writing RDF that extends N-Triples. It provides features like namespace prefixes for shorthand IRI notation, semicolon shorthand for multiple triples with the same subject, and support for collections and blank nodes using square bracket notation." ;
    schema:isPartOf :faqSection .

:q10 a schema:Question ;
    schema:name "What is JSON-LD?" ;
    schema:text "How does JSON-LD represent RDF data?" ;
    schema:acceptedAnswer :a10 ;
    schema:isPartOf :faqSection ;
    schema:hasPart :a10 .

:a10 a schema:Answer ;
    schema:name "What is JSON-LD? - Answer" ;
    schema:text "JSON-LD (JavaScript Object Notation for Linked Data) provides a JSON syntax for RDF graphs and datasets. It offers universal identifiers for JSON objects, mechanisms for linking to objects described elsewhere on the Web, and datatype and language handling. JSON-LD uses @context to map JSON keys to RDF vocabulary terms." ;
    schema:isPartOf :faqSection .

:q11 a schema:Question ;
    schema:name "What is Linked Data?" ;
    schema:text "What is the concept of Linked Data?" ;
    schema:acceptedAnswer :a11 ;
    schema:about <http://dbpedia.org/resource/Linked_Data> ;
    schema:isPartOf :faqSection ;
    schema:hasPart :a11 .

:a11 a schema:Answer ;
    schema:name "What is Linked Data? - Answer" ;
    schema:text "Linked Data refers to the practice of publishing and interlinking data on the Web using RDF. By following links between resources (such as retrieving bob's IRI to get data about him including links to his friends), persons or automated processes can aggregate data about various things from different datasets. This is a core principle of the Semantic Web." ;
    schema:isPartOf :faqSection .

:q12 a schema:Question ;
    schema:name "What is an RDF dataset?" ;
    schema:text "How do RDF datasets handle multiple graphs?" ;
    schema:acceptedAnswer :a12 ;
    schema:isPartOf :faqSection ;
    schema:hasPart :a12 .

:a12 a schema:Answer ;
    schema:name "What is an RDF dataset? - Answer" ;
    schema:text "An RDF dataset is a collection of RDF statements grouped into multiple graphs. It may have multiple named graphs and at most one unnamed (default) graph. Named graphs are associated with an IRI (graph name), allowing subsets of triples to be identified and queried separately, such as using SPARQL." ;
    schema:isPartOf :faqSection .

:glossarySection a schema:DefinedTermSet ;
    schema:name "RDF 1.2 Primer Glossary of Terms" ;
    schema:description "Key terminology used in the RDF 1.2 Primer document." ;
    schema:hasDefinedTerm :term-rdf , :term-triple , :term-iri , :term-literal , :term-blank-node , :term-graph , :term-vocabulary , :term-rdfs , :term-dataset , :term-turtle , :term-n-triples , :term-trig ;
    schema:isPartOf <> .

:term-rdf a schema:DefinedTerm ;
    schema:name "RDF (Resource Description Framework)" ;
    schema:definition "A framework for expressing information about resources. Resources can be anything including documents, people, physical objects, and abstract concepts. RDF provides a common framework for exchanging information between applications." ;
    schema:about <http://dbpedia.org/resource/Resource_Description_Framework> ;
    schema:isPartOf :glossarySection .

:term-triple a schema:DefinedTerm ;
    schema:name "RDF Triple" ;
    schema:definition "A statement consisting of three elements: subject, predicate, and object. The subject and object represent two resources being related, and the predicate represents the nature of their relationship expressed directionally." ;
    schema:about <http://dbpedia.org/resource/Triple_(information_technology)> ;
    schema:isPartOf :glossarySection .

:term-iri a schema:DefinedTerm ;
    schema:name "IRI (Internationalized Resource Identifier)" ;
    schema:definition "A global identifier for resources that generalizes URI by allowing non-ASCII characters. IRIs can appear in all three positions of an RDF triple and identify resources without implying location or access method." ;
    schema:about <http://dbpedia.org/resource/Internationalized_Resource_Identifier> ;
    schema:isPartOf :glossarySection .

:term-literal a schema:DefinedTerm ;
    schema:name "Literal" ;
    schema:definition "A value encoded in RDF such as strings, dates, or numbers. Literals are always associated with a datatype and may optionally have a language tag or base direction. They can only appear in the object position of a triple." ;
    schema:isPartOf :glossarySection .

:term-blank-node a schema:DefinedTerm ;
    schema:name "Blank Node" ;
    schema:definition "A resource without a global identifier, represented by identifiers like _:x in Turtle. Blank nodes can appear in subject and object positions of triples and function like variables in algebra." ;
    schema:isPartOf :glossarySection .

:term-graph a schema:DefinedTerm ;
    schema:name "RDF Graph" ;
    schema:definition "A set of RDF triples visualized as a connected graph with nodes (subjects and objects) and arcs (predicates). The same resource can be in multiple positions enabling discovery of connections between triples." ;
    schema:isPartOf :glossarySection .

:term-vocabulary a schema:DefinedTerm ;
    schema:name "RDF Vocabulary" ;
    schema:definition "A set of IRIs that provide semantic information about resources. Popular vocabularies include FOAF for social networks, Dublin Core for metadata, schema.org for web markup, and SKOS for classification schemes." ;
    schema:isPartOf :glossarySection .

:term-rdfs a schema:DefinedTerm ;
    schema:name "RDF Schema (RDFS)" ;
    schema:definition "A language for defining semantic characteristics of RDF data including classes, properties, domain and range restrictions, and class/property hierarchies using constructs like rdfs:Class, rdf:type, and rdfs:subClassOf." ;
    schema:isPartOf :glossarySection .

:term-dataset a schema:DefinedTerm ;
    schema:name "RDF Dataset" ;
    schema:definition "A collection of RDF statements grouped into multiple graphs. Contains multiple named graphs identified by IRIs and at most one unnamed (default) graph." ;
    schema:isPartOf :glossarySection .

:term-turtle a schema:DefinedTerm ;
    schema:name "Turtle (Terse RDF Triple Language)" ;
    schema:definition "A human-readable RDF syntax extending N-Triples with namespace prefixes, semicolon shorthand for multiple triples with same subject, and support for collections and blank nodes." ;
    schema:isPartOf :glossarySection .

:term-n-triples a schema:DefinedTerm ;
    schema:name "N-Triples" ;
    schema:definition "A simple line-based plain-text format for serializing RDF graphs. Each line represents a triple with full IRIs in angle brackets and period at the end. Used for exchanging large amounts of RDF." ;
    schema:isPartOf :glossarySection .

:term-trig a schema:DefinedTerm ;
    schema:name "TriG" ;
    schema:definition "An extension of Turtle enabling specification of multiple named graphs. Uses GRAPH blocks with curly braces to group triples under named graph IRIs." ;
    schema:isPartOf :glossarySection .

:howtoSection a schema:HowTo ;
    schema:name "How to Create RDF Triples" ;
    schema:description "A step-by-step guide to creating RDF triples from resources and their relationships." ;
    schema:step :step1 , :step2 , :step3 , :step4 , :step5 ;
    schema:isPartOf <> .

:step1 a schema:HowToStep ;
    schema:name "Identify the Subject Resource" ;
    schema:text "Choose the resource you want to make a statement about. This can be identified by an IRI such as http://example.org/bob#me or a blank node if the resource does not have a global identifier." ;
    schema:position 1 ;
    schema:isPartOf :howtoSection .

:step2 a schema:HowToStep ;
    schema:name "Choose the Predicate Property" ;
    schema:text "Select the property that describes the relationship between subject and object. Use an IRI for the predicate such as foaf:knows or schema:birthDate." ;
    schema:position 2 ;
    schema:isPartOf :howtoSection .

:step3 a schema:HowToStep ;
    schema:name "Determine the Object Value" ;
    schema:text "Decide what value to assign. This can be another resource identified by IRI or blank node, or a literal value such as strings, numbers, or dates." ;
    schema:position 3 ;
    schema:isPartOf :howtoSection .

:step4 a schema:HowToStep ;
    schema:name "Format as a Triple" ;
    schema:text "Combine the three components in order: subject predicate object. In Turtle syntax: <subject> <predicate> <object> . For example: <bob> foaf:knows <alice> ." ;
    schema:position 4 ;
    schema:isPartOf :howtoSection .

:step5 a schema:HowToStep ;
    schema:name "Serialize or Store the Triple" ;
    schema:text "Choose a serialization format such as Turtle, JSON-LD, RDF/XML, or N-Triples to write down your triples, or store them in an RDF database for SPARQL querying." ;
    schema:position 5 ;
    schema:isPartOf :howtoSection .

:section-Introduction a schema:ArticleSection ;
    schema:name "Introduction" ;
    schema:text "RDF is a framework for expressing information about resources. Resources can be anything, including documents, people, physical objects, and abstract concepts. RDF is intended for situations in which information on the Web needs to be processed by applications. RDF provides a common framework for exchanging information so it can be exchanged between applications without loss of meaning." ;
    schema:isPartOf <> ;
    schema:hasPart <> .

:section-use-cases a schema:ArticleSection ;
    schema:name "Why Use RDF?" ;
    schema:text "RDF enables adding machine-readable information to web pages using schema.org vocabulary, enriching datasets by linking to third-party datasets, interlinking API feeds, building distributed social networks, providing standards-compliant database data exchange, and enabling cross-dataset SPARQL queries." ;
    schema:isPartOf <> ;
    schema:hasPart <> .

:section-data-model a schema:ArticleSection ;
    schema:name "RDF Data Model" ;
    schema:text "The RDF data model describes triples (subject-predicate-object), IRIs for identifying resources, literals for encoding values, blank nodes for unnamed resources, triple terms for reification, and multiple graphs for datasets." ;
    schema:isPartOf <> ;
    schema:hasPart <> .

:section-vocabulary a schema:ArticleSection ;
    schema:name "RDF Vocabularies" ;
    schema:text "RDF vocabularies include RDF Schema for modeling, FOAF for social networks, Dublin Core for metadata, schema.org for web markup, and SKOS for classification schemes. Vocabularies get their value from reuse and the network effect." ;
    schema:isPartOf <> ;
    schema:hasPart <> .

:section-graph-syntax a schema:ArticleSection ;
    schema:name "Writing RDF Graphs" ;
    schema:text "RDF serialization formats include the Turtle family (N-Triples, Turtle, TriG, N-Quads), JSON-LD for JSON-based RDF, RDFa for HTML embedding, and RDF/XML as the original XML syntax." ;
    schema:isPartOf <> ;
    schema:hasPart <> .

:section-semantics a schema:ArticleSection ;
    schema:name "Semantics of RDF Graphs" ;
    schema:text "The semantics of RDF graphs are defined in terms of the abstract syntax in the RDF Semantics document. This provides formal model-theoretic semantics for RDF." ;
    schema:isPartOf <> ;
    schema:hasPart <> .

:section-data a schema:ArticleSection ;
    schema:name "RDF Data" ;
    schema:text "RDF data can be published and interlinked on the Web. Following links between resources allows persons or automated processes to aggregate data about various things from different datasets." ;
    schema:isPartOf <> ;
    schema:hasPart <> .

:section-conclusion a schema:ArticleSection ;
    schema:name "More Information" ;
    schema:text "For normative specifications, refer to RDF Concepts, RDF Semantics, Turtle specification, JSON-LD, RDFa, N-Triples, N-Quads, RDF/XML, and RDF Schema documents." ;
    schema:isPartOf <> ;
    schema:hasPart <> .

