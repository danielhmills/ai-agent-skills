      "@type": "Article",
      "name": {"@value": "The Semantic Medallion: Building a Knowledge Graph-Powered Data Catalog", "@language": "en"},
      "headline": {"@value": "How you can transform raw data sources into a unified knowledge graph in four lines of Python", "@language": "en"},
