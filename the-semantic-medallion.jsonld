    {
      "@id": "platinumLayerComment",
      "@type": "Comment",
      "author": {"@id": "https://www.linkedin.com/in/kidehen#this"},
      "text": {"@value": "And the Platinum Layer is when the RDF based Knowledge Graph is deployed using Linked Data principles i.e., knowledge construction that leverages the power of hyperlinks for entity and relationship naming that manifests a Semantic Web.", "@language": "en"},
      "about": [{"@id": "platinumLayer"}, {"@id": "analysis"}],
      "dateCreated": "2026-05-19",
      "isPartOf": {"@id": "analysis"}
    },

    {
      "@id": "technologiesSection",
      "@type": "ArticleSection",
      "name": {"@value": "Technologies and Standards", "@language": "en"},
      "description": {"@value": "Key technologies, standards, and tools referenced in the Semantic Medallion architecture.", "@language": "en"},
      "hasPart": [
        {"@id": "maplib"}, {"@id": "ottrTemplates"}, {"@id": "dcatVocabulary"},
        {"@id": "provOntology"}, {"@id": "sparqlQueryLanguage"}, {"@id": "rdfStandard"}
      ],
      "isPartOf": {"@id": "analysis"}
    },

    {
      "@id": "maplib",
      "@type": "SoftwareApplication",
      "name": "maplib",
      "description": {"@value": "A Python library that maps DataFrames to RDF using OTTR templates — enabling DataFrame-to-RDF transformation in as few as four lines of Python.", "@language": "en"},
      "programmingLanguage": "Python",
      "applicationCategory": "Data Transformation Library",
      "url": "https://pypi.org/project/maplib/"
    },

    {
      "@id": "ottrTemplates",
      "@type": "DefinedTerm",
      "name": {"@value": "OTTR Templates (stOTTR)", "@language": "en"},
      "description": {"@value": "Reasonable Ontology Templates — a templating language for RDF that maps structured data columns to ontology properties using declarative stOTTR syntax.", "@language": "en"},
      "rdfs:seeAlso": {"@id": "http://dbpedia.org/resource/Ontology_(information_science)"}
    },

    {
      "@id": "dcatVocabulary",
      "@type": "DefinedTerm",
      "name": {"@value": "DCAT — Data Catalog Vocabulary", "@language": "en"},
      "description": {"@value": "The W3C standard vocabulary for describing data catalogs, datasets, distributions, and data services. Used by data.gov, the European Data Portal, and thousands of organisations worldwide.", "@language": "en"},
      "url": "https://www.w3.org/TR/vocab-dcat-3/",
      "rdfs:seeAlso": {"@id": "http://www.w3.org/ns/dcat#"}
    },

    {
      "@id": "provOntology",
      "@type": "DefinedTerm",
      "name": {"@value": "PROV-O — Provenance Ontology", "@language": "en"},
      "description": {"@value": "The W3C standard ontology for representing provenance information — enabling data lineage as queryable triples rather than a separate lineage tool.", "@language": "en"},
      "url": "https://www.w3.org/TR/prov-o/",
      "rdfs:seeAlso": {"@id": "http://www.w3.org/ns/prov#"}
    },

    {
      "@id": "sparqlQueryLanguage",
      "@type": ["DefinedTerm", "ComputerLanguage"],
      "name": "SPARQL",
      "description": {"@value": "The W3C standard query language for RDF knowledge graphs — used to query the Gold layer for entity resolution, lineage tracing, and cross-system relationship navigation.", "@language": "en"},
      "url": "https://www.w3.org/TR/sparql11-query/"
    },

    {
      "@id": "rdfStandard",
      "@type": "DefinedTerm",
      "name": {"@value": "RDF — Resource Description Framework", "@language": "en"},
      "description": {"@value": "The W3C standard for representing linked data as subject-predicate-object triples, forming the foundation of the Semantic Gold layer.", "@language": "en"},
      "url": "https://www.w3.org/RDF/"
    },

    {
      "@id": "capabilitiesSection",
      "@type": "ArticleSection",
      "name": {"@value": "Semantic Data Catalog Capabilities", "@language": "en"},
      "description": {"@value": "The three key capabilities enabled by a Semantic Medallion-powered data catalog: entity resolution, semantic search, and impact analysis.", "@language": "en"},
      "hasPart": [
        {"@id": "entityResolutionCapability"},
        {"@id": "semanticSearchCapability"},
        {"@id": "impactAnalysisCapability"}
      ],
      "isPartOf": {"@id": "analysis"}
    },

    {
      "@id": "entityResolutionCapability",
      "@type": "DefinedTerm",
      "name": {"@value": "Entity Resolution Across Sources", "@language": "en"},
      "description": {"@value": "Using owl:sameAs to link entities appearing in CRM, billing, and external registries — providing a unified view of every record across all systems.", "@language": "en"},
      "isPartOf": {"@id": "capabilitiesSection"}
    },
    {
      "@id": "semanticSearchCapability",
      "@type": "DefinedTerm",
      "name": {"@value": "Semantic Search", "@language": "en"},
      "description": {"@value": "The ontology encodes subclass relationships enabling hierarchical search that understands concepts, not just keywords — e.g., searching for ComplianceRelated returns ComplianceOfficer, AuditRecord, and RegulatoryFiling.", "@language": "en"},
      "isPartOf": {"@id": "capabilitiesSection"}
    },
    {
      "@id": "impactAnalysisCapability",
      "@type": "DefinedTerm",
      "name": {"@value": "Impact Analysis", "@language": "en"},
      "description": {"@value": "Tracing graph relationships to find downstream dependencies when schemas change — identifying every dataset, report, and application affected by a modification.", "@language": "en"},
      "isPartOf": {"@id": "capabilitiesSection"}
    },

    {
      "@id": "architectureConceptsSection",
      "@type": "ArticleSection",
      "name": {"@value": "Architecture Concepts", "@language": "en"},
      "description": {"@value": "Core architectural concepts introduced by the Semantic Medallion approach, contrasting structural and semantic data catalogs.", "@language": "en"},
      "hasPart": [{"@id": "structuralCatalog"}, {"@id": "semanticCatalog"}],
      "isPartOf": {"@id": "analysis"}
    },
    {
      "@id": "structuralCatalog", "@type": "DefinedTerm",
      "name": {"@value": "Structural Data Catalog", "@language": "en"},
      "description": {"@value": "A traditional data catalog that describes where data lives (tables, columns, formats) but does not understand what things mean or how they relate.", "@language": "en"},
      "isPartOf": {"@id": "architectureConceptsSection"}
    },
    {
      "@id": "semanticCatalog", "@type": "DefinedTerm",
      "name": {"@value": "Semantic Data Catalog", "@language": "en"},
      "description": {"@value": "A knowledge graph-powered data catalog where metadata and data are unified in the same graph — the catalog is part of the knowledge graph rather than a separate system pointing at data.", "@language": "en"},
      "isPartOf": {"@id": "architectureConceptsSection"}
    },

