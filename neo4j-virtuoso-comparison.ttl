@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <#> .

<> a schema:Article ;
    schema:name "Neo4j Virtual Graph vs Virtuoso: A Comparative Analysis of Graph Virtualization Architectures"@en ;
    schema:headline "What Neo4j Just Announced, Virtuoso Has Been Doing for Two Decades"@en ;
    schema:description "Comparative analysis of Neo4j Virtual Graph (announced May 2026) and OpenLink Virtuoso's long-established virtual DBMS and Knowledge Graph capabilities. Examines architecture, data source breadth, query language support, federation, maturity, and the fundamental design philosophies behind each approach."@en ;
    schema:dateCreated "2026-06-03"^^xsd:date ;
    schema:author <https://linkedin.com/in/kidehen#this> ;
    schema:about :Neo4jVirtualGraph, :VirtuosoMultiModelPlatform ;
    schema:citation <https://neo4j.com/blog/graph-database/introducing-neo4j-virtual-graph-graph-reasoning-on-the-data-you-already-have/>,
                      <https://www.linkedin.com/feed/update/urn:li:ugcPost:7459616012645240832/> ;
    schema:keywords "Neo4j, Virtuoso, Virtual Graph, Knowledge Graph, RDF Views, SPARQL, Cypher, GQL, Graph Virtualization, Multi-Model Database, Semantic Property Graph"@en ;
    schema:mainEntity :ComparativeAnalysis .

# ─────────────────────────────────────────────────────────
# THE TWO SYSTEMS
# ─────────────────────────────────────────────────────────

:Neo4jVirtualGraph a schema:SoftwareApplication ;
    schema:name "Neo4j Virtual Graph"@en ;
    schema:version "Private Preview" ;
    schema:datePublished "2026-05-28"^^xsd:date ;
    schema:applicationCategory "Graph Virtualization Layer"@en ;
    schema:provider <https://neo4j.com/> ;
    schema:description "A zero-copy graph virtualization layer that lets users run Cypher queries and graph algorithms against data stored in external warehouses (Snowflake, Databricks) without moving or duplicating data. Uses AI-generated graph models, deterministic Cypher-to-SQL compilation, and a graph compute layer for traversals and algorithms."@en .

:VirtuosoMultiModelPlatform a schema:SoftwareApplication ;
    schema:name "OpenLink Virtuoso Universal Server"@en ;
    schema:version "8.x" ;
    schema:applicationCategory "Multi-Model Database and Middleware Platform"@en ;
    schema:provider <http://dbpedia.org/resource/OpenLink_Software> ;
    schema:description "A multi-model, multi-purpose platform that loosely couples SQL, SPARQL, openCypher, GQL, and GraphQL query languages to underlying data via a virtual DBMS architecture. Provides declarative RDF Views over relational data, cross-endpoint SPARQL federation, HTTP-based identifiers as universal keys, and native graph storage — all in a single, production-hardened engine with ACID guarantees."@en .

# ─────────────────────────────────────────────────────────
# COMPARATIVE ANALYSIS
# ─────────────────────────────────────────────────────────

:ComparativeAnalysis a schema:Analysis ;
    schema:name "Comparative Analysis: Neo4j Virtual Graph vs Virtuoso"@en ;
    schema:about :Neo4jVirtualGraph, :VirtuosoMultiModelPlatform ;
    schema:hasPart :CoreArchitecture, :DataSourceSupport, :QueryLanguageSupport,
                   :FederationCapability, :IdentifierPhilosophy, :MaturityAndAvailability,
                   :LatencyAndPerformance, :GraphAlgorithmSupport, :LicensingAndEcosystem,
                   :SummaryAssessment .

# ─────────────────────────────────────────────────────────
# 1. CORE ARCHITECTURE
# ─────────────────────────────────────────────────────────

:CoreArchitecture a schema:Analysis ;
    schema:name "Core Architecture"@en ;
    schema:hasPart :Neo4jArchitecture, :VirtuosoArchitecture .

:Neo4jArchitecture a schema:Analysis ;
    schema:name "Neo4j Virtual Graph Architecture"@en ;
    schema:text """Three-layer architecture:
1. AI-Generated Data Model — inspects source schema, infers nodes from columns, relationships from foreign keys, properties from remaining columns. User can edit visually.
2. Query Translator — deterministic Cypher-to-SQL compiler. Same Cypher always produces same SQL. Execution pushed down to warehouse engine.
3. Graph Compute Layer — handles pattern matching, traversals, and algorithms SQL alone cannot express efficiently.
Data never leaves the warehouse governance perimeter. All compute runs on the source system."""@en .

:VirtuosoArchitecture a schema:Analysis ;
    schema:name "Virtuoso Virtual DBMS Architecture"@en ;
    schema:text """Unified engine with declarative virtualization:
1. RDF Views — Declarative mapping rules (Quad Map Patterns) that define how relational tables and columns map to RDF classes, predicates, and instances. No AI required — mappings are explicit, auditable, and version-controllable SQL/SPARQL DDL.
2. SPARQL-to-SQL Rewriter — Compiles SPARQL patterns into optimized SQL that executes natively against the underlying relational storage. Deterministic, cost-based optimizer with decades of tuning.
3. Native Graph Storage — Alongside virtualization, Virtuoso stores RDF property graphs natively in its column-store engine with full ACID, real-time performance, and vector/hybrid search.
4. Cross-Endpoint Federation — SPARQL-FED queries can span local virtual graphs, local native graphs, and remote SPARQL endpoints (Wikidata, DBpedia) in a single query.
5. Multi-Protocol Hosting — Same engine hosts ODBC, JDBC, HTTP (REST/SOAP), SPARQL Protocol, GraphQL, and WebDAV interfaces concurrently."""@en .

# ─────────────────────────────────────────────────────────
# 2. DATA SOURCE SUPPORT
# ─────────────────────────────────────────────────────────

:DataSourceSupport a schema:Analysis ;
    schema:name "Data Source Support"@en ;
    schema:hasPart :Neo4jDataSources, :VirtuosoDataSources .

:Neo4jDataSources a schema:Analysis ;
    schema:name "Neo4j Virtual Graph Data Sources"@en ;
    schema:text """At launch (private preview): Snowflake and Databricks only.
Roadmap: any JDBC/SQL-accessible system.
No mention of RDF endpoints, SPARQL sources, NoSQL stores, or non-relational backends."""@en .

:VirtuosoDataSources a schema:Analysis ;
    schema:name "Virtuoso Data Sources"@en ;
    schema:text """Production-ready for decades:
- Any ODBC or JDBC accessible database (Oracle, SQL Server, PostgreSQL, MySQL, DB2, Snowflake, Databricks, etc.)
- Native Virtuoso storage (relational, RDF, hybrid)
- Remote SPARQL endpoints (Wikidata, DBpedia, any standards-compliant endpoint)
- RDF documents (Turtle, RDF/XML, JSON-LD, N-Triples, N-Quads)
- CSV, XML, JSON, and other structured data via built-in transformation
- WebDAV-mounted external storage
This breadth has been available since the early 2000s."""@en .

# ─────────────────────────────────────────────────────────
# 3. QUERY LANGUAGE SUPPORT
# ─────────────────────────────────────────────────────────

:QueryLanguageSupport a schema:Analysis ;
    schema:name "Query Language Support"@en ;
    schema:hasPart :Neo4jLanguages, :VirtuosoLanguages .

:Neo4jLanguages a schema:Analysis ;
    schema:name "Neo4j Query Languages"@en ;
    schema:text "Cypher only. GQL parity on roadmap. No SPARQL, no SQL as a first-class query surface. SQL is an internal compilation target, not user-facing."@en .

:VirtuosoLanguages a schema:Analysis ;
    schema:name "Virtuoso Query Languages"@en ;
    schema:text """All loosely coupled to the underlying data engine:
- SQL (including SQL/XML, SQL/JSON)
- SPARQL 1.1 (Query, Update, Federated Query, Graph Store Protocol)
- SPARQL inside SQL (SPASQL) for hybrid relational/graph queries
- openCypher
- GQL (preview, announced via LinkedIn post)
- GraphQL (via GraphQL-to-SPARQL bridge)
Each language compiles to the same internal execution engine. Language and storage are architecturally decoupled — the core design principle."""@en .

# ─────────────────────────────────────────────────────────
# 4. FEDERATION
# ─────────────────────────────────────────────────────────

:FederationCapability a schema:Analysis ;
    schema:name "Federation Capability"@en ;
    schema:hasPart :Neo4jFederation, :VirtuosoFederation .

:Neo4jFederation a schema:Analysis ;
    schema:name "Neo4j Federation"@en ;
    schema:text """Roadmap includes composite queries across AuraDB (native) and Virtual Graph (warehouse) in a single Cypher statement — self-managed only initially, Aura later.
No mention of cross-warehouse federation (e.g., joining Snowflake and Databricks in one query).
No mention of federating to external graph databases or SPARQL endpoints."""@en .

:VirtuosoFederation a schema:Analysis ;
    schema:name "Virtuoso Federation"@en ;
    schema:text """SPARQL-FED (W3C standard) enables a single query to span:
- Multiple Virtuoso instances (local and remote)
- Virtuoso-hosted RDF Views over different relational backends
- Third-party SPARQL endpoints (Wikidata, DBpedia, Europeana, etc.)
- Native RDF graphs and virtual RDF graphs in the same query
The LinkedIn demo specifically showed federated queries against Virtuoso-hosted Northwind RDF Views AND live Wikidata AND live DBpedia — three distinct data spaces in one SPARQL query.
SQL ATTACH TABLE enables cross-database SQL joins across remote sources."""@en .

# ─────────────────────────────────────────────────────────
# 5. IDENTIFIER PHILOSOPHY
# ─────────────────────────────────────────────────────────

:IdentifierPhilosophy a schema:Analysis ;
    schema:name "Identifier Philosophy"@en ;
    schema:hasPart :Neo4jIdentifiers, :VirtuosoIdentifiers .

:Neo4jIdentifiers a schema:Analysis ;
    schema:name "Neo4j Identifier Approach"@en ;
    schema:text "Neo4j uses internal node IDs and property-based identification. The Virtual Graph model infers nodes and relationships from column semantics and foreign keys. No emphasis on global, dereferenceable identifiers — identification is warehouse-scoped and internal to the graph model."@en .

:VirtuosoIdentifiers a schema:Analysis ;
    schema:name "Virtuoso Identifier Approach"@en ;
    schema:text """HTTP-based IRIs (Internationalized Resource Identifiers) serve as universal 'super keys' for entities. This is fundamental to the Semantic Property Graph approach:
- Every entity gets a globally unique, dereferenceable HTTP IRI
- IRIs function as foreign keys across databases, domains, and organizations
- Linked Data principles enable entity resolution across systems without ETL
- owl:sameAs assertions connect identities across platforms (LinkedIn → X → Wikidata → DBpedia)
- RDF Views declaratively map relational primary keys to IRI patterns
This is a philosophical difference, not just a technical one — it makes the Knowledge Graph a first-class citizen of the Web, not a database-internal construct."""@en .

# ─────────────────────────────────────────────────────────
# 6. MATURITY AND AVAILABILITY
# ─────────────────────────────────────────────────────────

:MaturityAndAvailability a schema:Analysis ;
    schema:name "Maturity and Availability"@en ;
    schema:hasPart :Neo4jMaturity, :VirtuosoMaturity .

:Neo4jMaturity a schema:Analysis ;
    schema:name "Neo4j Virtual Graph Maturity"@en ;
    schema:text """- Announced: May 28, 2026
- Status: Private Preview (invitation-only)
- Production readiness: Not yet. Explicitly labeled as preview.
- Time to GA: Unstated.
- Known limitations: Warehouse-grade latency (seconds-to-minutes), no real-time workloads, limited to Snowflake/Databricks at launch, reduced Cypher surface compared to native AuraDB."""@en .

:VirtuosoMaturity a schema:Analysis ;
    schema:name "Virtuoso Virtualization Maturity"@en ;
    schema:text """- RDF Views (virtual RDF over relational): Introduced circa 2006, production-stable for ~20 years
- SPARQL-to-SQL compilation: Mature, cost-based optimizer with decades of tuning
- Multi-model engine: SQL + SPARQL + openCypher + GQL + GraphQL all in production
- Deployment: Open source (GitHub) and commercial editions
- Track record: Powers DBpedia, Wikidata query service (historic), and enterprise Knowledge Graph deployments globally
- No warehouse-only limitation — same engine handles OLTP, OLAP, and federated graph queries"""@en .

# ─────────────────────────────────────────────────────────
# 7. LATENCY AND PERFORMANCE
# ─────────────────────────────────────────────────────────

:LatencyAndPerformance a schema:Analysis ;
    schema:name "Latency and Performance"@en ;
    schema:hasPart :Neo4jLatency, :VirtuosoLatency .

:Neo4jLatency a schema:Analysis ;
    schema:name "Neo4j Virtual Graph Latency Profile"@en ;
    schema:text """Neo4j's own guidance:
- "Agents that need to think in seconds — Virtual Graph is a fit"
- "Agents that need to act in milliseconds — you want the graph stored natively"
- Designed for batch and analytical agentic workloads
- SQL compilation adds overhead; queries execute on warehouse infrastructure
- Roadmap promises adaptive caching for hot subgraphs to reduce latency
- NOT suitable for real-time fraud detection, live identity resolution, or sub-second agent decisioning"""@en .

:VirtuosoLatency a schema:Analysis ;
    schema:name "Virtuoso Latency Profile"@en ;
    schema:text """Virtuoso's engine handles the full latency spectrum:
- Real-time: Native RDF storage with column-store engine delivers millisecond SPARQL performance for transactional workloads
- Analytical: SPARQL-to-SQL rewriting over RDF Views enables warehouse-scale analytical queries
- Federated: SPARQL-FED performance varies by remote endpoint responsiveness, but Virtuoso's adaptive query optimization pipelines result streams
- No forced trade-off — the same engine runs both OLTP (milliseconds) and OLAP (seconds-to-minutes) workloads
- Cost-based optimizer chooses execution strategies based on data locality, index availability, and join cardinality"""@en .

# ─────────────────────────────────────────────────────────
# 8. GRAPH ALGORITHM SUPPORT
# ─────────────────────────────────────────────────────────

:GraphAlgorithmSupport a schema:Analysis ;
    schema:name "Graph Algorithm Support"@en ;
    schema:hasPart :Neo4jAlgorithms, :VirtuosoAlgorithms .

:Neo4jAlgorithms a schema:Analysis ;
    schema:name "Neo4j Graph Algorithm Support"@en ;
    schema:text """Neo4j GDS (Graph Data Science) library provides a comprehensive suite of algorithms:
- Pathfinding: Dijkstra, A*, Yen's k-shortest paths
- Centrality: PageRank, Betweenness, Degree, Closeness
- Community detection: Louvain, Leiden, Label Propagation
- Similarity: Node Similarity, KNN
- All available through Virtual Graph against warehouse data
Demo example: detecting circular payment paths (fraud pattern) in warehouse data."""@en .

:VirtuosoAlgorithms a schema:Analysis ;
    schema:name "Virtuoso Graph Algorithm Support"@en ;
    schema:text """Graph analytics via SPARQL and extensions:
- SPARQL property paths for transitive closure, reachability, and pattern matching
- Built-in analytics via SQL (weighted degree centrality, etc.)
- Integration with external RDF reasoning and analytics libraries
- SPASQL enables embedding graph traversal patterns in SQL analytics queries
- SPARQL-FED allows algorithm input data to span multiple live endpoints
- Less emphasis on a packaged 'GDS library' — more on composable queries and federation
- Native vector/hybrid search for GraphRAG workloads"""@en .

# ─────────────────────────────────────────────────────────
# 9. LICENSING AND ECOSYSTEM
# ─────────────────────────────────────────────────────────

:LicensingAndEcosystem a schema:Analysis ;
    schema:name "Licensing and Ecosystem"@en ;
    schema:hasPart :Neo4jLicense, :VirtuosoLicense .

:Neo4jLicense a schema:Analysis ;
    schema:name "Neo4j Licensing"@en ;
    schema:text """- Neo4j Community Edition: open source (GPL), limited features
- Neo4j Enterprise Edition: commercial license, full feature set
- AuraDB (cloud): consumption-based pricing
- Virtual Graph: private preview, pricing undisclosed. Likely Aura-only at launch with premium pricing.
- GDS library: Enterprise-only for production use"""@en .

:VirtuosoLicense a schema:Analysis ;
    schema:name "Virtuoso Licensing"@en ;
    schema:text """- Open Source Edition: GitHub, full SPARQL + SQL + RDF Views, no license fees
- Commercial Edition: Enterprise features, support, and indemnification
- All virtualization capabilities (RDF Views, SPARQL-to-SQL, federation) are in the open source edition
- On-premises, cloud, or hybrid deployment — no vendor lock-in
- OpenLink provides commercial support, hosting, and professional services"""@en .

# ─────────────────────────────────────────────────────────
# 10. SUMMARY ASSESSMENT
# ─────────────────────────────────────────────────────────

:SummaryAssessment a schema:Analysis ;
    schema:name "Summary Assessment"@en ;
    schema:text """Neo4j Virtual Graph is a compelling entry into graph virtualization — but it is entering a space Virtuoso has occupied since the mid-2000s. The comparison is not between equals at different points in time; it is between a newly announced private preview and a decades-hardened production system.

Where Neo4j Leads:
- Packaged graph algorithm library (GDS) with strong developer UX
- AI-assisted graph model generation (though deterministic compilation preserves predictability)
- Brand recognition and community in the property graph space
- Clear narrative for GraphRAG and agentic AI workloads

Where Virtuoso Leads:
- Maturity: ~20 years of production virtualization vs private preview
- Data source breadth: Any ODBC/JDBC source vs Snowflake/Databricks only
- Query language breadth: SQL + SPARQL + openCypher + GQL + GraphQL vs Cypher only
- Federation: Cross-endpoint SPARQL-FED (W3C standard) with live Wikidata/DBpedia integration
- Identifier model: HTTP IRIs as universal keys enabling genuine Linked Data
- Latency spectrum: Real-time OLTP through analytical OLAP in one engine
- Licensing: Full virtualization in open source; no vendor lock-in
- Standards: W3C standards (SPARQL, RDF, Linked Data) vs Cypher (now an ISO standard via GQL)

Philosophical Difference:
Neo4j Virtual Graph adds a graph query layer over warehouses — graph reasoning on data you already have, where you already have it. This is an architectural pattern.
Virtuoso treats the graph as a first-class Web citizen — entities identified by HTTP IRIs, data virtualized through declarative mappings, and query languages as interchangeable interfaces to the same engine. This is a platform philosophy.

The most telling indicator: what Neo4j is announcing as a private preview in 2026 — 'run graph queries against your existing SQL data without moving it' — is exactly what Virtuoso's RDF Views and SPARQL-to-SQL rewriting have delivered, in production, since 2006. The difference is that Virtuoso adds federation, multi-language support, HTTP-based identifiers, and ACID-grade real-time performance on top."""@en .

# ─────────────────────────────────────────────────────────
# DEFINED TERMS / GLOSSARY
# ─────────────────────────────────────────────────────────

:VirtualGraph a schema:DefinedTerm ;
    schema:name "Virtual Graph"@en ;
    schema:description "A graph representation layered over data that remains in its original storage system. Queries against the virtual graph are translated to the source system's native query language (typically SQL), avoiding data duplication while enabling graph-pattern queries."@en .

:RDFViews a schema:DefinedTerm ;
    schema:name "RDF Views"@en ;
    schema:description "Declarative mapping rules in Virtuoso that define how relational tables and columns correspond to RDF classes, predicates, and instances. Enable SPARQL queries to execute against relational data by compiling to SQL. The foundational mechanism behind Virtuoso's virtual graph capability, introduced circa 2006."@en .

:SPARQLFederation a schema:DefinedTerm ;
    schema:name "SPARQL Federation (SPARQL-FED)"@en ;
    schema:description "A W3C standard extension to SPARQL that allows a single query to span multiple SPARQL endpoints. The SERVICE keyword directs portions of a query to specific remote endpoints, with results joined locally. Enables cross-database, cross-organization graph queries without data centralization."@en .

:SemanticPropertyGraph a schema:DefinedTerm ;
    schema:name "Semantic Property Graph"@en ;
    schema:description "An approach that combines property graph query languages (Cypher, GQL) with RDF's HTTP-based identifiers and semantics. Nodes and edges carry both internal properties and globally unique IRIs, enabling the graph to participate in the Web of Linked Data."@en .

:GraphRAG a schema:DefinedTerm ;
    schema:name "GraphRAG"@en ;
    schema:description "Graph Retrieval-Augmented Generation — using graph queries (traversals, pattern matching, pathfinding) to retrieve structured context for LLM prompts. Contrasts with vector-only RAG by preserving relationship structure that would be lost in embedding-based retrieval."@en .

:ZeroCopyArchitecture a schema:DefinedTerm ;
    schema:name "Zero-Copy Architecture"@en ;
    schema:description "A data integration approach where queries execute against data in its original location without creating a duplicate copy. Eliminates ETL pipelines and maintains the source system as the system of record. Both Neo4j Virtual Graph and Virtuoso RDF Views implement zero-copy patterns, though through different mechanisms."@en .

# ─────────────────────────────────────────────────────────
# FAQ
# ─────────────────────────────────────────────────────────

:FAQ a schema:FAQPage ;
    schema:name "Frequently Asked Questions"@en ;
    schema:mainEntity :FAQ1, :FAQ2, :FAQ3, :FAQ4, :FAQ5 .

:FAQ1 a schema:Question ;
    schema:name "Is Neo4j Virtual Graph the same as Virtuoso RDF Views?"@en ;
    schema:acceptedAnswer [
        a schema:Answer ;
        schema:text "Conceptually similar, but with important differences. Both compile graph query languages to SQL for zero-copy execution against external data. However, Virtuoso RDF Views use declarative, auditable mapping rules (not AI-generated models), support SPARQL as well as openCypher and GQL, federate across remote endpoints, and have been production-hardened for ~20 years versus Neo4j's newly-announced private preview."@en
    ] .

:FAQ2 a schema:Question ;
    schema:name "Which is better for GraphRAG?"@en ;
    schema:acceptedAnswer [
        a schema:Answer ;
        schema:text "Both approach GraphRAG from different angles. Neo4j Virtual Graph targets 'test GraphRAG value without building pipelines' — a low-friction on-ramp for Snowflake/Databricks users. Virtuoso provides a broader GraphRAG foundation with federation (spanning internal databases AND public knowledge graphs like Wikidata/DBpedia), HTTP-based entity identifiers that ground LLM outputs in dereferenceable URIs, and vector/hybrid search alongside SPARQL. The right choice depends on your existing infrastructure, standards requirements, and whether you need federation beyond a single warehouse."@en
    ] .

:FAQ3 a schema:Question ;
    schema:name "Does Virtuoso support Cypher and GQL?"@en ;
    schema:acceptedAnswer [
        a schema:Answer ;
        schema:text "Yes. Virtuoso has an openCypher preview and a GQL preview (announced via LinkedIn in late 2025). These are loosely coupled to Virtuoso's engine alongside SQL, SPARQL, and GraphQL — meaning you can use Cypher or GQL syntax to query the same data accessible via SPARQL or SQL. This multi-language approach is a deliberate architectural choice: decouple query language from data representation."@en
    ] .

:FAQ4 a schema:Question ;
    schema:name "Can Neo4j Virtual Graph query Virtuoso?"@en ;
    schema:acceptedAnswer [
        a schema:Answer ;
        schema:text "Not directly, but interestingly the reverse is possible. Virtuoso's JDBC/ODBC interface means it could theoretically appear as a data source for Neo4j Virtual Graph once Neo4j expands beyond Snowflake/Databricks to general JDBC sources. Conversely, Virtuoso can already query Neo4j via Neo4j's SPARQL plugin or through SPARQL-FED if Neo4j exposes a SPARQL endpoint."@en
    ] .

:FAQ5 a schema:Question ;
    schema:name "What is the key philosophical difference between the two approaches?"@en ;
    schema:acceptedAnswer [
        a schema:Answer ;
        schema:text "Neo4j Virtual Graph adds graph queries to your existing warehouse — it is a feature layered on top of your data infrastructure. Virtuoso treats the graph as a first-class Web citizen — entities have HTTP IRIs, data is linked across systems via those IRIs, and query languages are interchangeable interfaces to a unified engine. One is a graph capability add-on; the other is a platform built on the architectural principle that data, information, and knowledge are distinct layers best served by decoupling query language from storage model."@en
    ] .
