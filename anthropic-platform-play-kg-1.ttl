:anthropicStrategy a schema:Concept ;
    schema:name "Anthropic Platform Strategy" ;
    schema:description "Enterprise-first approach: subsidise to capture, then extract. Focus on platform and application layers rather than model commoditization." ;
    rdfs:isDefinedBy : .

