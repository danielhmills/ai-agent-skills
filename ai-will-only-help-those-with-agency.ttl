@base <https://dejiolowe.com/2026/03/30/ai-will-only-help-those-with-agency/> .

<https://dejiolowe.com/2026/03/30/ai-will-only-help-those-with-agency/> a schema:Article ;
    schema:name "AI will only help those with agency" ;
    schema:headline "AI will only help those with agency" ;
    schema:description "AI will help those with agency and screw up everyone else. The distance between the 1% and the rest will be the widest the world has ever seen." ;
    schema:url <https://dejiolowe.com/2026/03/30/ai-will-only-help-those-with-agency/> ;
    schema:datePublished "2026-03-30" ;
    schema:dateModified "2026-03-30" ;
    schema:author [
        a schema:Person ;
        schema:name "Adedeji Olowe" ;
        schema:url <https://dejiolowe.com/author/dejiolowe/> ;
        foaf:homepage <https://dejiolowe.com/>
    ] ;
    schema:publisher [
        a schema:Person ;
        schema:name "Adedeji Olowe" ;
        foaf:homepage <https://dejiolowe.com/>
    ] ;
    schema:about <https://dejiolowe.com/2026/03/30/ai-will-only-help-those-with-agency/#topic> ;
    schema:keywords "AI, agency, productivity, tools, technology, entrepreneurship, Africa" ;
    schema:articleSection "General" .

<#topic> a schema:Thing ;
    schema:name "AI and Human Agency" ;
    dcterms:description "The relationship between AI capabilities and human agency, taste, grit, and curiosity in determining productivity outcomes." .

<https://dejiolowe.com/author/dejiolowe/> a schema:Person ;
    schema:name "Adedeji Olowe" ;
    schema:jobTitle "Founder/CEO" ;
    schema:worksFor [
        a schema:Organization ;
        schema:name "Lendsqr"
    ] ;
    foaf:weblog <https://dejiolowe.com/> .

ex:KeyTraits a schema:Thing ;
    schema:name "Key Traits for AI Success" ;
    schema:description "Four key traits identified for extracting real value from AI tools" ;
    schema:hasPart (
        ex:agency
        ex:taste
        ex:grit
        ex:curiosity
    ) .

ex:agency a schema:Thing ;
    schema:name "Agency" ;
    schema:description "The most visible factor - the ability to decide to take action and follow through on it" ;
    schema:text "Nothing really progresses without someone deciding to take action and following through on it. AI responds to direction, and without that initial push, there is nothing for it to build on." .

ex:taste a schema:Thing ;
    schema:name "Taste" ;
    schema:description "Knowing when something is actually good - carrying a clear internal standard that pushes you to improve output" ;
    schema:text "You don't need to be wildly creative to have taste, you just need to carry a clear internal standard that pushes you to look at something and say this is not good enough yet, this can still be better." .

ex:grit a schema:Thing ;
    schema:name "Grit" ;
    schema:description "Staying long enough for it to get good - the patience to iterate and refine" ;
    schema:text "Staying with something long enough for it to mature into what you actually had in mind. The loop of refining, adjusting, and pushing further is where most of the real work happens." .

ex:curiosity a schema:Thing ;
    schema:name "Curiosity" ;
    schema:description "The engine behind improvement - engaging with AI in an exploratory way" ;
    schema:text "People who get the most out of AI tend to engage with it in a more exploratory way. They are not just issuing instructions and moving on; they are probing, questioning, and trying to understand why something works the way it does." .

ex:mentionedTools a schema:Thing ;
    schema:name "Tools Mentioned" ;
    schema:hasPart (
        <https://openai.com/codex/>
        <https://www.zoho.com/>
        <https://www.freshworks.com/freshservice/business-teams/>
        <https://www.getcarbon.co/>
    ) .

<https://openai.com/codex/> a schema:SoftwareApplication ;
    schema:name "OpenAI Codex Pro" ;
    schema:description "Pro version of Codex from Open AI mentioned for building internal tools" .

<https://www.getcarbon.co/> a schema:Organization ;
    schema:name "Carbon" ;
    schema:description "Nigerian fintech company co-founded by Ngozi Dozie" .

ex:PersonalAnectodes a schema:CreativeWork ;
    schema:name "Personal Anecdotes" ;
    schema:description "Stories shared in the article about building an internal HRMS and selling vibe-coded products" .

ex:buildingInternalHRMS a schema:Event ;
    schema:name "Building Internal HRMS" ;
    schema:description "Adedeji Olowe built an internal HRMS for his team using OpenAI Codex Pro, replacing Freshteam before it was discontinued" .

ex:vibeCodedSale a schema:Event ;
    schema:name "$20k Vibe-Coded Product Sale" ;
    schema:description "A security expert built a Drata/Vanta replacement via vibe-coding and sold it for $20k to a CISO" .

ex:claudeCodeSubscription a schema:Event ;
    schema:name "$20 Claude Code Subscription" ;
    schema:description "Ngozi Dozie documented what he accomplished with just a $20 Claude Code subscription" .

