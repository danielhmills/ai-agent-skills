##############################################
# Instance Data — Gold Layer
##############################################

:Gold-RDF-KG a dcat:Dataset ;
    dct:title "Gold RDF Knowledge Graph"@en ;
    dct:format "text/turtle" ;
    dct:issued "2026-05-14T08:00:00Z"^^xsd:dateTime ;
    schema:description "The unified Gold layer knowledge graph — all customer, billing, contract, agent, and compliance entities connected via typed RDF relationships."@en ;
    dcat:distribution :Gold-TTL-Distribution ;
    dcat:contactPoint [ a schema:ContactPoint ;
        schema:email "data-team@example.com" ] .

:Gold-TTL-Distribution a dcat:Distribution ;
    dct:title "Gold KG Turtle Distribution"@en ;
    dct:format "text/turtle" ;
    dcat:accessURL <https://linkeddata.uriburner.com/DAV/demos/daas/semantic-medallion-deepseek_v4pro-1.ttl> .

:Gold-SPARQL-Endpoint a dcat:DataService ;
    dct:title "Gold Layer SPARQL Endpoint"@en ;
    dcat:endpointURL "https://linkeddata.uriburner.com/sparql" ;
    schema:description "SPARQL endpoint serving the unified Gold layer knowledge graph."@en ;
    dcat:servesDataset :Gold-RDF-KG .

##############################################
# DCAT Catalog (unified metadata)
##############################################

:SemanticDataCatalog a dcat:Catalog ;
    dct:title "Semantic Medallion Data Catalog"@en ;
    dct:description "A DCAT catalog describing all datasets in the Semantic Medallion architecture — Bronze raw sources, Silver structured distributions, and the Gold RDF knowledge graph."@en ;
    dct:issued "2026-05-14T08:00:00Z"^^xsd:dateTime ;
    dcat:dataset :Bronze-Raw-CRM, :Bronze-Raw-Billing, :Bronze-Raw-External ;
    dcat:dataset :Gold-RDF-KG ;
    dcat:service :Gold-SPARQL-Endpoint .

:Bronze-Raw-CRM a dcat:Dataset ;
    dct:title "CRM Raw Data (Bronze)"@en ;
    dct:format "application/json" ;
    schema:description "Raw CRM data ingested from Salesforce — original JSON format."@en ;
    dcat:distribution [ a dcat:Distribution ;
        dct:title "CRM Raw JSON"@en ;
        dct:format "application/json" ] .

:Bronze-Raw-Billing a dcat:Dataset ;
    dct:title "Billing Raw Data (Bronze)"@en ;
    dct:format "text/csv" ;
    schema:description "Raw billing data ingested from Stripe — original CSV format."@en ;
    dcat:distribution [ a dcat:Distribution ;
        dct:title "Billing Raw CSV"@en ;
        dct:format "text/csv" ] .

:Bronze-Raw-External a dcat:Dataset ;
    dct:title "External Registry Raw Data (Bronze)"@en ;
    dct:format "application/xml" ;
    schema:description "Raw external registry data from Dun & Bradstreet — original XML format."@en ;
    dcat:distribution [ a dcat:Distribution ;
        dct:title "External Registry Raw XML"@en ;
        dct:format "application/xml" ] .

##############################################
# Provenance — Customer-to-Source Links
##############################################

:C-001 prov:wasDerivedFrom :CRM-Salesforce, :Billing-Stripe .

:C-002 prov:wasDerivedFrom :CRM-Salesforce, :External-DB .

:C-003 prov:wasDerivedFrom :CRM-Salesforce .

:C-004 prov:wasDerivedFrom :CRM-Salesforce, :Billing-Stripe, :External-DB .

:CRM-Salesforce prov:hadPrimarySource :Bronze-Raw-CRM .
:Billing-Stripe prov:hadPrimarySource :Bronze-Raw-Billing .
:External-DB prov:hadPrimarySource :Bronze-Raw-External .

:Bronze-Raw-CRM dcat:distribution [ a dcat:Distribution ; dct:format "application/json" ; dct:title "CRM Raw JSON Feed"@en ] .
:Bronze-Raw-Billing dcat:distribution [ a dcat:Distribution ; dct:format "text/csv" ; dct:title "Billing Raw CSV Feed"@en ] .
:Bronze-Raw-External dcat:distribution [ a dcat:Distribution ; dct:format "application/xml" ; dct:title "External Registry XML Feed"@en ] .

