##############################################
# Instance Data — Data Sources
##############################################

:CRM-Salesforce a :DataSource, dcat:Dataset ;
    schema:name "Salesforce CRM"@en ;
    schema:identifier "DS-CRM-001" ;
    schema:description "Customer master records, contacts, opportunities, and account plans from the Salesforce CRM platform."@en ;
    schema:url "https://salesforce.example.com" ;
    prov:hadPrimarySource :CRM-Ingestion-Job .

:Billing-Stripe a :DataSource, dcat:Dataset ;
    schema:name "Stripe Billing System"@en ;
    schema:identifier "DS-BILL-001" ;
    schema:description "Subscription billing data, invoices, payment records, and dispute cases from the Stripe payment platform."@en ;
    schema:url "https://stripe.example.com" ;
    prov:hadPrimarySource :Billing-Ingestion-Job .

:External-DB a :DataSource, dcat:Dataset ;
    schema:name "Dun & Bradstreet External Registry"@en ;
    schema:identifier "DS-EXT-001" ;
    schema:description "External business registry data from Dun & Bradstreet — company profiles, industry classifications, and credit ratings."@en ;
    schema:url "https://dnb.example.com" ;
    prov:hadPrimarySource :External-Ingestion-Job .

