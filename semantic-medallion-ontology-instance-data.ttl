@prefix : <http://example.org/ontology#> .
@prefix schema: <http://schema.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .

##############################################
# Domain Ontology
##############################################

: a owl:Ontology ;
    rdfs:label "Semantic Medallion Domain Ontology"@en ;
    rdfs:comment "An executable instance-data ontology for the Semantic Medallion article — modeling Customer, BillingIssue, Contract, DataSource, and supporting entities to make the article's three SPARQL queries return verifiable results."@en ;
    owl:imports <http://www.w3.org/ns/dcat#> , <http://www.w3.org/ns/prov#> ;
    rdfs:isDefinedBy : .

# --- Classes ---

:Customer a rdfs:Class ;
    rdfs:label "Customer"@en ;
    rdfs:comment "A customer entity — may appear across CRM, billing, and support systems."@en ;
    rdfs:isDefinedBy : .

:BillingIssue a rdfs:Class ;
    rdfs:label "Billing Issue"@en ;
    rdfs:comment "A billing-related issue associated with a customer, such as a disputed charge or overdue payment."@en ;
    rdfs:isDefinedBy : .

:Contract a rdfs:Class ;
    rdfs:label "Contract"@en ;
    rdfs:comment "A service or license agreement associated with a customer."@en ;
    rdfs:isDefinedBy : .

:DataSource a rdfs:Class ;
    rdfs:label "Data Source"@en ;
    rdfs:comment "An upstream data source that contributes records — e.g., CRM, billing system, external registry."@en ;
    rdfs:subClassOf prov:Entity ;
    rdfs:isDefinedBy : .

:Agent a rdfs:Class ;
    rdfs:label "Agent"@en ;
    rdfs:comment "A sales, support, or service agent associated with customer interactions."@en ;
    rdfs:isDefinedBy : .

:ComplianceRelated a rdfs:Class ;
    rdfs:label "Compliance Related"@en ;
    rdfs:comment "A superclass for all compliance-related entities — demonstrating semantic search via subclass hierarchies."@en ;
    rdfs:isDefinedBy : .

:ComplianceOfficer a rdfs:Class ;
    rdfs:subClassOf :ComplianceRelated ;
    rdfs:label "Compliance Officer"@en ;
    rdfs:comment "An individual responsible for compliance oversight."@en ;
    rdfs:isDefinedBy : .

:AuditRecord a rdfs:Class ;
    rdfs:subClassOf :ComplianceRelated ;
    rdfs:label "Audit Record"@en ;
    rdfs:comment "A record of a compliance audit or review."@en ;
    rdfs:isDefinedBy : .

:RegulatoryFiling a rdfs:Class ;
    rdfs:subClassOf :ComplianceRelated ;
    rdfs:label "Regulatory Filing"@en ;
    rdfs:comment "A document filed with a regulatory body."@en ;
    rdfs:isDefinedBy : .

# --- Object Properties ---

:hasBillingIssue a rdf:Property ;
    rdfs:label "has billing issue"@en ;
    rdfs:comment "Links a customer to an open billing issue."@en ;
    rdfs:domain :Customer ;
    rdfs:range :BillingIssue ;
    rdfs:isDefinedBy : .

:hasActiveContract a rdf:Property ;
    rdfs:label "has active contract"@en ;
    rdfs:comment "Links a customer to an active service contract."@en ;
    rdfs:domain :Customer ;
    rdfs:range :Contract ;
    rdfs:isDefinedBy : .

:managedBy a rdf:Property ;
    rdfs:label "managed by"@en ;
    rdfs:comment "Links a customer to the agent managing their account."@en ;
    rdfs:domain :Customer ;
    rdfs:range :Agent ;
    rdfs:isDefinedBy : .

:originatesFrom a rdf:Property ;
    rdfs:label "originates from"@en ;
    rdfs:comment "Links a customer record to the data source system from which it originated."@en ;
    rdfs:domain :Customer ;
    rdfs:range :DataSource ;
    rdfs:isDefinedBy : .

:hasEmail a rdf:Property ;
    rdfs:label "has email"@en ;
    rdfs:comment "Links a customer to their email address."@en ;
    rdfs:domain :Customer ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

:hasPhone a rdf:Property ;
    rdfs:label "has phone"@en ;
    rdfs:comment "Links a customer to their phone number."@en ;
    rdfs:domain :Customer ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

:customerSince a rdf:Property ;
    rdfs:label "customer since"@en ;
    rdfs:comment "The date a customer relationship was established."@en ;
    rdfs:domain :Customer ;
    rdfs:range xsd:date ;
    rdfs:isDefinedBy : .

:hasRevenue a rdf:Property ;
    rdfs:label "has revenue"@en ;
    rdfs:comment "Annual revenue associated with a customer."@en ;
    rdfs:domain :Customer ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

:hasComplianceRequirement a rdf:Property ;
    rdfs:label "has compliance requirement"@en ;
    rdfs:comment "Links an entity to a compliance requirement it must satisfy."@en ;
    rdfs:domain rdfs:Resource ;
    rdfs:range :ComplianceRelated ;
    rdfs:isDefinedBy : .

